	"patch": [
		{
			"name": "pi-simple",
			"patch": "--- file.txt\n+++ file.txt\n@@ -1,3 +1,3 @@\n one\n-two\n+TWO\n three\n"
		},
		{
			"name": "pi-no-newline-at-eof",
			"patch": "--- edit.txt\n+++ edit.txt\n@@ -1,1 +1,1 @@\n-Hello, world!\n\\ No newline at end of file\n+Hello, testing!\n\\ No newline at end of file\n"
		},
		{
			"name": "pi-insertion-only",
			"patch": "--- file.txt\n+++ file.txt\n@@ -1,2 +1,3 @@\n a\n+x\n b\n"
		},
		{
			"name": "zero-lines-quirk",
			"patch": "--- file.txt\n+++ file.txt\n@@ -2,1 +1,0 @@\n-b\n"
		},
		{
			"name": "two-hunks",
			"patch": "--- file.txt\n+++ file.txt\n@@ -1,2 +1,2 @@\n-h1\n+H1\n c1\n@@ -11,2 +11,2 @@\n c10\n-h2\n+H2\n"
		},
		{
			"name": "identical-files",
			"patch": "--- file.txt\n+++ file.txt\n"
		},
		{
			"name": "include-headers-same-name",
			"patch": "Index: file.txt\n===================================================================\n--- file.txt\n+++ file.txt\n@@ -1,3 +1,3 @@\n one\n-two\n+TWO\n three\n"
		},
		{
			"name": "include-headers-different-names",
			"patch": "===================================================================\n--- old.txt\n+++ new.txt\n@@ -1,3 +1,3 @@\n one\n-two\n+TWO\n three\n"
		},
		{
			"name": "omit-headers",
			"patch": "@@ -1,3 +1,3 @@\n one\n-two\n+TWO\n three\n"
		},
		{
			"name": "crlf-file",
			"patch": "--- file.txt\n+++ file.txt\n@@ -1,2 +1,2 @@\n a\r\n-b\r\n+c\r\n"
		},
		{
			"name": "no-newline-then-context",
			"patch": "--- file.txt\n+++ file.txt\n@@ -1,3 +1,3 @@\n a\n-b\n+B\n c\n\\ No newline at end of file\n"
		}
	]
}
