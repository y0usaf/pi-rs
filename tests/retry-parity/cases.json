{
  "model": {
    "id": "retry-oracle", "name": "Retry Oracle", "provider": "anthropic",
    "api": "anthropic-messages", "baseUrl": "", "reasoning": false, "input": ["text"],
    "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
    "contextWindow": 200000, "maxTokens": 1024
  },
  "cases": [
    { "name": "classify-overloaded", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "overloaded_error" } },
    { "name": "classify-provider-returned", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "Provider returned error" } },
    { "name": "classify-rate-limit", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "Rate limit reached" } },
    { "name": "classify-too-many", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "Too many requests" } },
    { "name": "classify-statuses", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "upstream 502" } },
    { "name": "classify-service", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "Service unavailable" } },
    { "name": "classify-network", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "Provider finish_reason: network_error" } },
    { "name": "classify-connection-lost", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "connection lost while reading" } },
    { "name": "classify-websocket", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "WebSocket closed unexpectedly" } },
    { "name": "classify-fetch", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "fetch failed" } },
    { "name": "classify-premature-stream", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "stream ended before message_stop" } },
    { "name": "classify-http2", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "HTTP2 request did not get a response" } },
    { "name": "classify-timeout", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "request timed out" } },
    { "name": "classify-retry-delay", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "retry delay exceeded" } },
    { "name": "exclude-context-overflow", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "prompt is too long: 213462 tokens > 200000 maximum" } },
    { "name": "exclude-usage-limit", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "GoUsageLimitError 429" } },
    { "name": "exclude-balance", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "insufficient available balance: 500" } },
    { "name": "exclude-quota", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "insufficient_quota rate limit" } },
    { "name": "exclude-billing", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "billing server error" } },
    { "name": "exclude-nonerror-stop", "mode": "classify", "message": { "stopReason": "stop", "errorMessage": "429" } },
    { "name": "exclude-empty", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "" } },
    { "name": "exclude-unrelated", "mode": "classify", "message": { "stopReason": "error", "errorMessage": "invalid_api_key" } },

    { "name": "retry-once-success", "mode": "run", "settings": { "enabled": true, "maxRetries": 3, "baseDelayMs": 1 }, "turns": [
      { "stopReason": "error", "errorMessage": "overloaded_error" }, { "text": "recovered" }
    ] },
    { "name": "retry-with-queued-followup", "mode": "run", "settings": { "enabled": true, "maxRetries": 3, "baseDelayMs": 1 }, "queueOnRetry": "queued while retrying", "turns": [
      { "stopReason": "error", "errorMessage": "overloaded_error" }, { "text": "recovered" }, { "text": "queued answer" }
    ] },
    { "name": "retry-twice-success", "mode": "run", "settings": { "enabled": true, "maxRetries": 3, "baseDelayMs": 2 }, "turns": [
      { "stopReason": "error", "errorMessage": "network error" }, { "stopReason": "error", "errorMessage": "503 server error" }, { "text": "recovered" }
    ] },
    { "name": "retry-exhausted", "mode": "run", "settings": { "enabled": true, "maxRetries": 2, "baseDelayMs": 1 }, "turns": [
      { "stopReason": "error", "errorMessage": "overloaded_error" }, { "stopReason": "error", "errorMessage": "429" }, { "stopReason": "error", "errorMessage": "connection lost" }
    ] },
    { "name": "retry-disabled", "mode": "run", "settings": { "enabled": false, "maxRetries": 3, "baseDelayMs": 1 }, "turns": [
      { "stopReason": "error", "errorMessage": "overloaded_error" }
    ] },
    { "name": "retry-nonretryable", "mode": "run", "settings": { "enabled": true, "maxRetries": 3, "baseDelayMs": 1 }, "turns": [
      { "stopReason": "error", "errorMessage": "invalid_api_key" }
    ] },
    { "name": "retry-cancelled", "mode": "run", "settings": { "enabled": true, "maxRetries": 3, "baseDelayMs": 100 }, "cancelAttempt": 1, "turns": [
      { "stopReason": "error", "errorMessage": "overloaded_error" }
    ] }
  ]
}
