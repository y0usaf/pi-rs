{
  "command": "interactive-extension-ui-parity-sequence",
  "columns": 72,
  "rows": 30,
  "extensions": [
    "examples/extensions/commands.lua",
    "examples/extensions/permission-gate.lua"
  ],
  "steps": [
    { "name": "startup" },
    { "name": "commands-open", "submit": "/commands extension" },
    { "name": "commands-confirm", "input": ["\u001b[B", "\r"] },
    { "name": "commands-notify", "input": ["\r"] },
    { "name": "permission-open", "permission": "sudo true" },
    { "name": "permission-blocked", "input": ["\u001b[B", "\r"] },
    { "name": "resize", "resize": { "columns": 48, "rows": 24 } }
  ]
}
