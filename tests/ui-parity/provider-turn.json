      "read-answer-turn": [
        { "event": "message_start", "data": { "type": "message_start", "message": { "id": "msg_answer", "type": "message", "role": "assistant", "content": [], "stop_reason": null, "usage": { "input_tokens": 64, "output_tokens": 1 } } } },
