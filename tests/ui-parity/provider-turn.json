      { "status": 400, "json": { "type": "error", "error": { "type": "invalid_request_error", "message": "Simulated failure for parity" } } }
    ]
  },
  "steps": [
    {
      "input": ["Say", " ", "hello", " ", "please", "\r"],
      "captures": [
        { "name": "working", "event": "message_start", "role": "user" },
        { "name": "streaming", "event": "message_update", "count": 2 },
        { "name": "turn-complete", "event": "agent_end" }
      ]
    },
    {
      "input": ["Read", " ", "notes.txt", "\r"],
      "captures": [
        { "name": "tool-streaming", "event": "message_update", "count": 5 },
        { "name": "tool-pending", "event": "tool_execution_start" },
        { "name": "tool-executed", "event": "tool_execution_end" },
        { "name": "tool-complete", "event": "agent_end" }
      ]
    },
    { "name": "tools-expanded", "input": ["\u000f"] },
    { "name": "tools-collapsed", "input": ["\u000f"] },
    {
      "input": ["Tell", " ", "me", " ", "a", " ", "story", "\r"],
      "captures": [
        { "name": "cancel-streaming", "event": "message_update", "count": 3, "action": "escape" },
        { "name": "cancelled", "event": "agent_end" }
      ]
    },
    {
      "input": ["Trigger", " ", "an", " ", "error", "\r"],
      "captures": [
        { "name": "failed", "event": "agent_end" }
      ]
    },
