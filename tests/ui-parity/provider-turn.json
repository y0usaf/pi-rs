        { "event": "message_start", "data": { "type": "message_start", "message": { "id": "msg_read", "type": "message", "role": "assistant", "content": [], "stop_reason": null, "usage": { "input_tokens": 25, "cache_read_input_tokens": 256, "cache_creation_input_tokens": 128, "output_tokens": 1 } } } },
        { "event": "content_block_start", "data": { "type": "content_block_start", "index": 0, "content_block": { "type": "text", "text": "" } } },
