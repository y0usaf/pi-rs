      "story-hang": [
        { "event": "message_start", "data": { "type": "message_start", "message": { "id": "msg_story", "type": "message", "role": "assistant", "content": [], "stop_reason": null, "usage": { "input_tokens": 18, "output_tokens": 1 } } } },
        { "event": "content_block_start", "data": { "type": "content_block_start", "index": 0, "content_block": { "type": "text", "text": "" } } },
