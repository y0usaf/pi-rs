#!/bin/sh
# Deterministic fd stand-in for the autocomplete-turn scenario. Both the Pi
# and pi-rs drivers spawn this instead of a real fd so the @-fuzzy pipeline
# (spawn, parse, trailing-slash directory markers, scoring, display) is
# pinned against identical output regardless of the machine. Arguments are
# ignored on purpose; filtering happens in the providers.
printf 'src/\n'
printf 'src/main.rs\n'
printf 'src/lib.rs\n'
printf 'docs/\n'
printf 'docs/guide.md\n'
printf 'README.md\n'
printf 'my folder/\n'
printf 'my folder/notes.txt\n'
