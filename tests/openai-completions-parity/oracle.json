{
	"cases": [
		{
			"name": "rich-stream",
			"requests": [
				{
					"method": "POST",
					"path": "/chat/completions",
					"headers": {
						"accept": "application/json",
						"authorization": "Bearer key",
						"content-type": "application/json",
						"x-extra": "yes"
					},
					"body": {
						"model": "gpt-5-mini",
						"messages": [
							{
								"role": "developer",
								"content": "You are helpful."
							},
							{
								"role": "user",
								"content": [
									{
										"type": "text",
										"text": "hello"
									},
									{
										"type": "image_url",
										"image_url": {
											"url": "data:image/png;base64,aW1n"
										}
									}
								]
							},
							{
								"role": "assistant",
								"content": "using tool",
								"reasoning_content": "old thought",
								"tool_calls": [
									{
										"id": "call_1",
										"type": "function",
										"function": {
											"name": "read",
											"arguments": "{\"path\":\"x\"}"
										}
									}
								]
							},
							{
								"role": "tool",
								"content": "done",
								"tool_call_id": "call_1"
							},
							{
								"role": "user",
								"content": [
									{
										"type": "text",
										"text": "Attached image(s) from tool result:"
									},
									{
										"type": "image_url",
										"image_url": {
											"url": "data:image/png;base64,aW1n"
										}
									}
								]
							}
						],
						"stream": true,
						"stream_options": {
							"include_usage": true
						},
						"store": false,
						"max_completion_tokens": 1234,
						"temperature": 0.2,
						"tools": [
							{
								"type": "function",
								"function": {
									"name": "read",
									"description": "Read",
									"parameters": {
										"type": "object",
										"properties": {
											"path": {
												"type": "string"
											}
										},
										"required": [
											"path"
										]
									},
									"strict": false
								}
							}
						],
						"tool_choice": "auto",
						"reasoning_effort": "high"
					}
				}
			],
			"events": [
				{
					"type": "start"
				},
				{
					"type": "text_start",
					"contentIndex": 0
				},
				{
					"type": "text_delta",
					"contentIndex": 0,
					"delta": "Answer "
				},
				{
					"type": "thinking_start",
					"contentIndex": 1
				},
				{
					"type": "thinking_delta",
					"contentIndex": 1,
					"delta": "Think "
				},
				{
					"type": "toolcall_start",
					"contentIndex": 2
				},
				{
					"type": "toolcall_delta",
					"contentIndex": 2,
					"delta": "{\"path\":"
				},
				{
					"type": "toolcall_delta",
					"contentIndex": 2,
					"delta": "\"a\"}"
				},
				{
					"type": "text_end",
					"contentIndex": 0,
					"content": "Answer "
				},
				{
					"type": "thinking_end",
					"contentIndex": 1,
					"content": "Think "
				},
				{
					"type": "toolcall_end",
					"contentIndex": 2,
					"toolCall": {
						"type": "toolCall",
						"id": "call_new",
						"name": "read",
						"arguments": {
							"path": "a"
						},
						"thoughtSignature": "{\"type\":\"reasoning.encrypted\",\"id\":\"call_new\",\"data\":\"sig\"}"
					}
				},
				{
					"type": "done",
					"reason": "toolUse"
				}
			],
			"result": {
				"role": "assistant",
				"content": [
					{
						"type": "text",
						"text": "Answer "
					},
					{
						"type": "thinking",
						"thinking": "Think ",
						"thinkingSignature": "reasoning_content"
					},
					{
						"type": "toolCall",
						"id": "call_new",
						"name": "read",
						"arguments": {
							"path": "a"
						},
						"thoughtSignature": "{\"type\":\"reasoning.encrypted\",\"id\":\"call_new\",\"data\":\"sig\"}"
					}
				],
				"api": "openai-completions",
				"provider": "openai",
				"model": "gpt-5-mini",
				"usage": {
					"input": 15,
					"output": 5,
					"cacheRead": 4,
					"cacheWrite": 1,
					"totalTokens": 25,
					"cost": {
						"input": 0.0000037499999999999997,
						"output": 0.000009999999999999999,
						"cacheRead": 1.0000000000000001e-7,
						"cacheWrite": 0,
						"total": 0.00001385
					}
				},
				"stopReason": "toolUse",
				"timestamp": 0,
				"responseId": "chat_1",
				"responseModel": "different-model"
			}
		},
