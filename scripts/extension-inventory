#!/usr/bin/env python3
"""Check/generate the closed Pi v0.79.0 extension-surface inventory."""

from __future__ import annotations

import argparse
import json
import re
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
TYPES = ROOT / "ref/pi/packages/coding-agent/src/core/extensions/types.ts"
LOADER = ROOT / "ref/pi/packages/coding-agent/src/core/extensions/loader.ts"
RUNNER = ROOT / "ref/pi/packages/coding-agent/src/core/extensions/runner.ts"
RESOURCE_LOADER = ROOT / "ref/pi/packages/coding-agent/src/core/resource-loader.ts"
EXAMPLES = ROOT / "ref/pi/packages/coding-agent/examples/extensions"
MANIFEST = ROOT / "tests/extension-inventory/manifest.json"
OUTPUT = ROOT / "EXTENSION_INVENTORY.md"


def interface_body(source: str, name: str) -> str:
    match = re.search(rf"export interface {re.escape(name)}(?:\s+extends\s+[^{{]+)?\s*{{", source)
    if not match:
        raise ValueError(f"missing interface {name}")
    start = match.end()
    depth = 1
    i = start
    while i < len(source) and depth:
        if source.startswith("//", i):
            i = source.find("\n", i)
            if i < 0:
                break
        elif source.startswith("/*", i):
            i = source.find("*/", i + 2)
            if i < 0:
                break
            i += 2
        elif source[i] == "{":
            depth += 1
            i += 1
        elif source[i] == "}":
            depth -= 1
            i += 1
        else:
            i += 1
    if depth:
        raise ValueError(f"unterminated interface {name}")
    return source[start : i - 1]


def interface_members(source: str, name: str) -> list[str]:
    body = interface_body(source, name)
    body = re.sub(r"/\*[\s\S]*?\*/|//[^\n]*", "", body)
    members: list[str] = []
    start = 0
    braces = parens = brackets = 0
    for i, char in enumerate(body):
        if char == "{":
            braces += 1
        elif char == "}":
            braces -= 1
        elif char == "(":
            parens += 1
        elif char == ")":
            parens -= 1
        elif char == "[":
            brackets += 1
        elif char == "]":
            brackets -= 1
        elif char == ";" and braces == 0 and parens == 0 and brackets == 0:
            statement = body[start:i].strip()
            match = re.match(
                r"(?:readonly\s+)?([A-Za-z_$][\w$]*)\??\s*(?:<[^;]+?>)?\s*(?:\(|:)",
                statement,
            )
            if match:
                members.append(match.group(1))
            start = i + 1
    return sorted(set(members))


def extract() -> dict[str, list[str]]:
    types = TYPES.read_text()
    loader = LOADER.read_text()
    resource = RESOURCE_LOADER.read_text()
    runner = RUNNER.read_text()

    event_interfaces = re.findall(r"export interface ([A-Za-z0-9_]*Event)\b", types)
    events = []
    for interface in event_interfaces:
        match = re.search(r'\btype:\s*"([^"]+)"', interface_body(types, interface))
        if match:
            events.append(match.group(1))
    events = sorted(set(events))
    for alias, event_name in (("ToolCallEvent", "tool_call"), ("ToolResultEvent", "tool_result")):
        if not re.search(rf"export type {alias}\s*=", types):
            raise ValueError(f"missing event alias {alias}")
        events.append(event_name)
    events = sorted(set(events))
    api = interface_members(types, "ExtensionAPI")
    ui = interface_members(types, "ExtensionUIContext")
    context = interface_members(types, "ExtensionContext")
    command_context = interface_members(types, "ExtensionCommandContext")

    rules = {
        "direct .lua files",
        "subdirectory init.lua entry",
        "project-local before global",
        "configured/CLI path resolution",
        "resolved-path deduplication",
        "project trust gate",
        "disable discovery but retain CLI paths",
        "isolated load failures",
        "async extension initialization",
        "per-extension attribution",
        "tool/flag conflict diagnostics",
        "first-registration tool precedence",
        "duplicate command disambiguation",
    }
    # Fail if the pinned implementation anchors backing the rule inventory move.
    anchors = {
        "loader.ts": [
            "async function loadExtension(",
            "await factory(api)",
            "export async function loadExtensions(",
            "function discoverExtensionsInDir(",
            "const localExtDir",
            "const globalExtDir",
        ],
        "resource-loader.ts": [
            "this.noExtensions",
            "loadProjectTrustExtensions",
            "addExtensionConflictDiagnostics",
            "detectExtensionConflicts",
            "loadFinalExtensionSet",
        ],
        "runner.ts": [
            "getAllRegisteredTools()",
            "getShortcuts(",
            "resolveRegisteredCommands()",
            "emitToolCall(",
            "emitToolResult(",
        ],
    }
    for file_name, needles in anchors.items():
        if file_name == "loader.ts":
            haystack = loader
        elif file_name == "runner.ts":
            haystack = runner
        else:
            haystack = resource
        for needle in needles:
            if needle not in haystack:
                raise ValueError(f"missing pinned {file_name} anchor: {needle}")

    examples = sorted(
        str(path.relative_to(EXAMPLES))
        for path in EXAMPLES.rglob("*.ts")
        if not path.name.endswith(".test.ts") and path.name != "test.ts"
    )
    return {
        "events": events,
        "api": api,
        "ui": ui,
        "context": context,
        "command_context": command_context,
        "loader_rules": sorted(rules),
        "examples": examples,
    }


def validate(extracted: dict[str, list[str]], manifest: dict) -> None:
    if manifest.get("oracle") != "Pi v0.79.0 c5582102":
        raise ValueError("manifest oracle must be Pi v0.79.0 c5582102")
    categories = manifest.get("categories", {})
    if set(categories) != set(extracted):
        raise ValueError(
            f"manifest categories differ: expected {sorted(extracted)}, got {sorted(categories)}"
        )
    allowed = re.compile(r"^(implemented|planned 9\.[1-8]|DESIGN exception [0-9]+)$")
    for category, names in extracted.items():
        groups = categories[category]
        rows: dict[str, dict] = {}
        if not isinstance(groups, list):
            raise ValueError(f"{category}: expected status groups")
        for group in groups:
            status = str(group.get("status", ""))
            evidence = str(group.get("evidence", "")).strip()
            if not allowed.match(status):
                raise ValueError(f"{category}: invalid status {status!r}")
            if not evidence:
                raise ValueError(f"{category}: evidence/target is required")
            for item in group.get("items", []):
                if item in rows:
                    raise ValueError(f"{category}.{item}: classified more than once")
                rows[item] = {"status": status, "evidence": evidence}
        if set(rows) != set(names):
            missing = sorted(set(names) - set(rows))
            stale = sorted(set(rows) - set(names))
            raise ValueError(f"{category}: missing={missing}, stale={stale}")


def render(extracted: dict[str, list[str]], manifest: dict) -> str:
    titles = {
        "events": "Events",
        "api": "ExtensionAPI members",
        "ui": "Extension UI operations",
        "context": "ExtensionContext fields/actions",
        "command_context": "ExtensionCommandContext-only actions",
        "loader_rules": "Loader/resource rules",
        "examples": "Reference examples",
    }
    lines = [
        "# Extension parity inventory",
        "",
        "Generated by `scripts/extension-inventory` from pinned Pi v0.79.0",
        "(`ref/pi` @ `c5582102`). Edit `tests/extension-inventory/manifest.json`,",
        "then regenerate; `--check` fails for any unclassified source member/example.",
        "",
        "Statuses are closed: `implemented`, `planned 9.x`, or an explicit DESIGN exception.",
        "",
    ]
    for category, names in extracted.items():
        lines += [f"## {titles[category]}", "", "| Surface | Status | Evidence / target |", "|---|---|---|"]
        rows = {}
        for group in manifest["categories"][category]:
            for item in group["items"]:
                rows[item] = group
        for name in names:
            row = rows[name]
            escaped = name.replace("|", "\\|")
            evidence = row["evidence"].replace("|", "\\|")
            lines.append(f"| `{escaped}` | {row['status']} | {evidence} |")
        lines.append("")
    counts = ", ".join(f"{key}={len(value)}" for key, value in extracted.items())
    lines += [f"Inventory counts: {counts}.", ""]
    return "\n".join(lines)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--check", action="store_true")
    parser.add_argument("--print-extracted", action="store_true", help=argparse.SUPPRESS)
    args = parser.parse_args()
    try:
        extracted = extract()
        if args.print_extracted:
            print(json.dumps(extracted, indent=2))
            return 0
        manifest = json.loads(MANIFEST.read_text())
        validate(extracted, manifest)
        generated = render(extracted, manifest)
        if args.check:
            current = OUTPUT.read_text() if OUTPUT.exists() else ""
            if current != generated:
                print(f"{OUTPUT.relative_to(ROOT)} is stale; run scripts/extension-inventory", file=sys.stderr)
                return 1
            print("extension inventory is complete and current")
            return 0
        OUTPUT.write_text(generated)
        print(f"wrote {OUTPUT.relative_to(ROOT)}")
        return 0
    except (OSError, ValueError, json.JSONDecodeError) as error:
        print(f"extension inventory: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
