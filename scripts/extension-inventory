#!/usr/bin/env python3
"""Check/generate the closed Pi v0.79.0 extension-surface inventory."""

from __future__ import annotations

import argparse
import json
import re
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
TYPES = ROOT / "ref/pi/packages/coding-agent/src/core/extensions/types.ts"
LOADER = ROOT / "ref/pi/packages/coding-agent/src/core/extensions/loader.ts"
RUNNER = ROOT / "ref/pi/packages/coding-agent/src/core/extensions/runner.ts"
RESOURCE_LOADER = ROOT / "ref/pi/packages/coding-agent/src/core/resource-loader.ts"
EXAMPLES = ROOT / "ref/pi/packages/coding-agent/examples/extensions"
MANIFEST = ROOT / "tests/extension-inventory/manifest.json"
PINNED_SURFACE = ROOT / "tests/extension-inventory/pinned-surface.json"
OUTPUT = ROOT / "EXTENSION_INVENTORY.md"
API_DOC = ROOT / "docs/lua-extension-api.md"


def interface_body(source: str, name: str) -> str:
    match = re.search(rf"export interface {re.escape(name)}(?:\s+extends\s+[^{{]+)?\s*{{", source)
    if not match:
        raise ValueError(f"missing interface {name}")
    start = match.end()
    depth = 1
    i = start
    while i < len(source) and depth:
        if source.startswith("//", i):
            i = source.find("\n", i)
            if i < 0:
                break
        elif source.startswith("/*", i):
            i = source.find("*/", i + 2)
            if i < 0:
                break
            i += 2
        elif source[i] == "{":
            depth += 1
            i += 1
        elif source[i] == "}":
            depth -= 1
            i += 1
        else:
            i += 1
    if depth:
        raise ValueError(f"unterminated interface {name}")
    return source[start : i - 1]


def interface_members(source: str, name: str) -> list[str]:
    body = interface_body(source, name)
    body = re.sub(r"/\*[\s\S]*?\*/|//[^\n]*", "", body)
    members: list[str] = []
    start = 0
    braces = parens = brackets = 0
    for i, char in enumerate(body):
        if char == "{":
            braces += 1
        elif char == "}":
            braces -= 1
        elif char == "(":
            parens += 1
        elif char == ")":
            parens -= 1
        elif char == "[":
            brackets += 1
        elif char == "]":
            brackets -= 1
        elif char == ";" and braces == 0 and parens == 0 and brackets == 0:
            statement = body[start:i].strip()
            match = re.match(
                r"(?:readonly\s+)?([A-Za-z_$][\w$]*)\??\s*(?:<[^;]+?>)?\s*(?:\(|:)",
                statement,
            )
            if match:
                members.append(match.group(1))
            start = i + 1
    return sorted(set(members))


def extract_from_ref() -> dict[str, list[str]]:
    types = TYPES.read_text()
    loader = LOADER.read_text()
    resource = RESOURCE_LOADER.read_text()
    runner = RUNNER.read_text()

    event_interfaces = re.findall(r"export interface ([A-Za-z0-9_]*Event)\b", types)
    events = []
    for interface in event_interfaces:
        match = re.search(r'\btype:\s*"([^"]+)"', interface_body(types, interface))
        if match:
            events.append(match.group(1))
    events = sorted(set(events))
    for alias, event_name in (("ToolCallEvent", "tool_call"), ("ToolResultEvent", "tool_result")):
        if not re.search(rf"export type {alias}\s*=", types):
            raise ValueError(f"missing event alias {alias}")
        events.append(event_name)
    events = sorted(set(events))
    api = interface_members(types, "ExtensionAPI")
    ui = interface_members(types, "ExtensionUIContext")
    context = interface_members(types, "ExtensionContext")
    command_context = interface_members(types, "ExtensionCommandContext")

    rules = {
        "direct .lua files",
        "subdirectory init.lua entry",
        "project-local before global",
        "configured/CLI path resolution",
        "resolved-path deduplication",
        "project trust gate",
        "disable discovery but retain CLI paths",
        "isolated load failures",
        "async extension initialization",
        "per-extension attribution",
        "tool/flag conflict diagnostics",
        "first-registration tool precedence",
        "duplicate command disambiguation",
    }
    # Fail if the pinned implementation anchors backing the rule inventory move.
    anchors = {
        "loader.ts": [
            "async function loadExtension(",
            "await factory(api)",
            "export async function loadExtensions(",
            "function discoverExtensionsInDir(",
            "const localExtDir",
            "const globalExtDir",
        ],
        "resource-loader.ts": [
            "this.noExtensions",
            "loadProjectTrustExtensions",
            "addExtensionConflictDiagnostics",
            "detectExtensionConflicts",
            "loadFinalExtensionSet",
        ],
        "runner.ts": [
            "getAllRegisteredTools()",
            "getShortcuts(",
            "resolveRegisteredCommands()",
            "emitToolCall(",
            "emitToolResult(",
        ],
    }
    for file_name, needles in anchors.items():
        if file_name == "loader.ts":
            haystack = loader
        elif file_name == "runner.ts":
            haystack = runner
        else:
            haystack = resource
        for needle in needles:
            if needle not in haystack:
                raise ValueError(f"missing pinned {file_name} anchor: {needle}")

    examples = sorted(
        str(path.relative_to(EXAMPLES))
        for path in EXAMPLES.rglob("*.ts")
        if not path.name.endswith(".test.ts") and path.name != "test.ts"
    )
    return {
        "events": events,
        "api": api,
        "ui": ui,
        "context": context,
        "command_context": command_context,
        "loader_rules": sorted(rules),
        "examples": examples,
    }

def extract() -> dict[str, list[str]]:
    fixture = json.loads(PINNED_SURFACE.read_text())
    if fixture.get("oracle") != "Pi v0.79.0 c5582102":
        raise ValueError("pinned surface oracle must be Pi v0.79.0 c5582102")
    surface = fixture.get("surface")
    if not isinstance(surface, dict):
        raise ValueError("pinned surface fixture has no surface object")
    if TYPES.exists():
        actual = extract_from_ref()
        if actual != surface:
            raise ValueError("pinned surface fixture differs from ref/pi; regenerate from the pinned revision")
    return surface


def validate(extracted: dict[str, list[str]], manifest: dict) -> None:
    if manifest.get("oracle") != "Pi v0.79.0 c5582102":
        raise ValueError("manifest oracle must be Pi v0.79.0 c5582102")
    categories = manifest.get("categories", {})
    if set(categories) != set(extracted):
        raise ValueError(
            f"manifest categories differ: expected {sorted(extracted)}, got {sorted(categories)}"
        )
    allowed = re.compile(r"^(implemented|planned 9\.[1-8]|DESIGN exception [0-9]+)$")
    for category, names in extracted.items():
        groups = categories[category]
        rows: dict[str, dict] = {}
        if not isinstance(groups, list):
            raise ValueError(f"{category}: expected status groups")
        for group in groups:
            status = str(group.get("status", ""))
            evidence = str(group.get("evidence", "")).strip()
            if not allowed.match(status):
                raise ValueError(f"{category}: invalid status {status!r}")
            if not evidence:
                raise ValueError(f"{category}: evidence/target is required")
            for item in group.get("items", []):
                if item in rows:
                    raise ValueError(f"{category}.{item}: classified more than once")
                rows[item] = {"status": status, "evidence": evidence}
        if set(rows) != set(names):
            missing = sorted(set(names) - set(rows))
            stale = sorted(set(rows) - set(names))
            raise ValueError(f"{category}: missing={missing}, stale={stale}")

    translations = manifest.get("translations", [])
    if not isinstance(translations, list):
        raise ValueError("translations: expected a list")
    translated: dict[str, dict] = {}
    for row in translations:
        source = str(row.get("source", ""))
        lua_path = str(row.get("lua", ""))
        evidence = str(row.get("evidence", "")).strip()
        if source in translated:
            raise ValueError(f"translations.{source}: classified more than once")
        if source not in extracted["examples"]:
            raise ValueError(f"translations.{source}: stale source")
        if not lua_path.startswith("examples/extensions/") or not lua_path.endswith(".lua"):
            raise ValueError(f"translations.{source}: invalid Lua path {lua_path!r}")
        path = ROOT / lua_path
        if not path.is_file():
            raise ValueError(f"translations.{source}: missing {lua_path}")
        if not evidence:
            raise ValueError(f"translations.{source}: CI evidence is required")
        translated[source] = row
        tests = (ROOT / "crates/pi-rs-app/tests/extension_loading.rs").read_text()
        if f"fn {evidence}(" not in tests:
            raise ValueError(f"translations.{source}: missing integration test {evidence}")
    implemented = {
        item
        for group in categories["examples"]
        if group["status"] == "implemented"
        for item in group["items"]
    }
    if set(translated) != implemented:
        missing = sorted(implemented - set(translated))
        stale = sorted(set(translated) - implemented)
        raise ValueError(f"translations: missing={missing}, non-implemented={stale}")


def render(extracted: dict[str, list[str]], manifest: dict) -> str:
    titles = {
        "events": "Events",
        "api": "ExtensionAPI members",
        "ui": "Extension UI operations",
        "context": "ExtensionContext fields/actions",
        "command_context": "ExtensionCommandContext-only actions",
        "loader_rules": "Loader/resource rules",
        "examples": "Reference examples",
    }
    lines = [
        "# Extension parity inventory",
        "",
        "Generated by `scripts/extension-inventory` from pinned Pi v0.79.0",
        "(`ref/pi` @ `c5582102`). Edit `tests/extension-inventory/manifest.json`,",
        "then regenerate; `--check` fails for any unclassified source member/example.",
        "",
        "Statuses are closed: `implemented`, `planned 9.x`, or an explicit DESIGN exception.",
        "",
    ]
    for category, names in extracted.items():
        lines += [f"## {titles[category]}", "", "| Surface | Status | Evidence / target |", "|---|---|---|"]
        rows = {}
        for group in manifest["categories"][category]:
            for item in group["items"]:
                rows[item] = group
        for name in names:
            row = rows[name]
            escaped = name.replace("|", "\\|")
            evidence = row["evidence"].replace("|", "\\|")
            lines.append(f"| `{escaped}` | {row['status']} | {evidence} |")
        lines.append("")
    counts = ", ".join(f"{key}={len(value)}" for key, value in extracted.items())
    lines += [f"Inventory counts: {counts}.", ""]
    return "\n".join(lines)

def snake_case(name: str) -> str:
    return re.sub(r"(?<!^)(?=[A-Z])", "_", name).lower()


def rows_by_name(manifest: dict, category: str) -> dict[str, dict]:
    return {
        item: group
        for group in manifest["categories"][category]
        for item in group["items"]
    }


def render_api_docs(extracted: dict[str, list[str]], manifest: dict) -> str:
    rows = {category: rows_by_name(manifest, category) for category in extracted}
    translations = {row["source"]: row for row in manifest["translations"]}
    lines = [
        "# Lua extension API",
        "",
        "Generated by `scripts/extension-inventory` from the checked Pi v0.79.0 surface fixture.",
        "Do not edit this file directly.",
        "",
        "An extension is a Lua file whose chunk receives `pi` as its first argument:",
        "",
        "```lua",
        "local pi = ...",
        "pi.on(\"tool_call\", function(event, ctx) return nil end)",
        "```",
        "",
        "Top-level Pi API names use Lua `snake_case`. Event names and Pi-compatible",
        "event/context/UI table fields retain their pinned spellings. `implemented` means",
        "the public path has executable evidence; `planned 9.x` remains unavailable or",
        "incomplete and must not be treated as a compatibility promise yet.",
        "",
        "All callers share one public surface. Embedded packages receive no private API.",
        "Low-level additive mechanisms (`pi.fs`, `pi.tui`, `pi.ai`, etc.) are separate",
        "Lua-native capabilities and do not change this Pi-compatible vocabulary.",
        "",
        "## ExtensionAPI",
        "",
        "| Pi member | Lua | Status |",
        "|---|---|---|",
    ]
    for name in extracted["api"]:
        lines.append(f"| `{name}` | `pi.{snake_case(name)}` | {rows['api'][name]['status']} |")
    lines += ["", "## Events", "", "| Event | Status |", "|---|---|"]
    for name in extracted["events"]:
        lines.append(f"| `{name}` | {rows['events'][name]['status']} |")
    for category, title, prefix in (
        ("context", "ExtensionContext", "ctx"),
        ("command_context", "ExtensionCommandContext-only", "ctx"),
        ("ui", "Extension UI", "ctx.ui"),
    ):
        lines += ["", f"## {title}", "", "| Pi-compatible field/action | Status |", "|---|---|"]
        for name in extracted[category]:
            lines.append(f"| `{prefix}.{name}` | {rows[category][name]['status']} |")
    lines += [
        "",
        "## Reference translation matrix",
        "",
        "Every pinned source is classified. A Lua path is published only after the",
        "translation loads and its representative behavior executes in CI.",
        "",
        "| Pinned TypeScript | Lua translation | Status | Evidence / dependency |",
        "|---|---|---|---|",
    ]
    for name in extracted["examples"]:
        status = rows["examples"][name]["status"]
        row = translations.get(name)
        lua_path = f"`{row['lua']}`" if row else "—"
        evidence = row["evidence"] if row else rows["examples"][name]["evidence"]
        lines.append(f"| `{name}` | {lua_path} | {status} | {evidence} |")
    counts = f"translated={len(translations)}, pinned={len(extracted['examples'])}"
    lines += ["", f"Matrix counts: {counts}.", ""]
    return "\n".join(lines)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--check", action="store_true")
    parser.add_argument("--print-extracted", action="store_true", help=argparse.SUPPRESS)
    args = parser.parse_args()
    try:
        extracted = extract()
        if args.print_extracted:
            print(json.dumps(extracted, indent=2))
            return 0
        manifest = json.loads(MANIFEST.read_text())
        validate(extracted, manifest)
        generated = render(extracted, manifest)
        api_doc = render_api_docs(extracted, manifest)
        if args.check:
            stale = []
            for path, expected in ((OUTPUT, generated), (API_DOC, api_doc)):
                current = path.read_text() if path.exists() else ""
                if current != expected:
                    stale.append(str(path.relative_to(ROOT)))
            if stale:
                print(f"stale generated files: {', '.join(stale)}; run scripts/extension-inventory", file=sys.stderr)
                return 1
            print("extension inventory, translation matrix, and Lua API docs are complete and current")
            return 0
        OUTPUT.write_text(generated)
        API_DOC.parent.mkdir(parents=True, exist_ok=True)
        API_DOC.write_text(api_doc)
        print(f"wrote {OUTPUT.relative_to(ROOT)} and {API_DOC.relative_to(ROOT)}")
        return 0
    except (OSError, ValueError, json.JSONDecodeError) as error:
        print(f"extension inventory: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
