#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."
if [[ ! -x ref/pi/node_modules/.bin/tsx ]]; then
  nix shell nixpkgs#nodejs_22 --command sh -c 'cd ref/pi && corepack npm ci --ignore-scripts'
fi
nix shell nixpkgs#nodejs_22 --command \
  ref/pi/node_modules/.bin/tsx --tsconfig ref/pi/tsconfig.json \
  tests/openai-codex-websocket-parity/gen-oracle.ts tests/openai-codex-websocket-parity/cases.json \
  > tests/openai-codex-websocket-parity/oracle.json
echo "wrote tests/openai-codex-websocket-parity/oracle.json"
