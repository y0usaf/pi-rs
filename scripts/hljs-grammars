#!/usr/bin/env bash
# Regenerate the compiled highlight.js 10.7.3 grammar catalog from the
# vendored library in ref/pi. The catalog is the data half of pi-rs's
# syntax-highlighting mechanism (crates/pi-rs-host/src/hljs); see
# tests/hljs-parity/gen-grammars.ts for scope and serialization notes.
set -euo pipefail
cd "$(dirname "$0")/.."
out=crates/pi-rs-host/data/hljs-grammars.json
if [[ ! -x ref/pi/node_modules/.bin/tsx ]]; then
  nix shell nixpkgs#nodejs_22 --command sh -c 'cd ref/pi && corepack npm ci --ignore-scripts'
fi
nix shell nixpkgs#nodejs_22 --command \
  ref/pi/node_modules/.bin/tsx --tsconfig ref/pi/tsconfig.json \
  tests/hljs-parity/gen-grammars.ts > "$out"
echo "wrote $out ($(du -h "$out" | cut -f1))"
