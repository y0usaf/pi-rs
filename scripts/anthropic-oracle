#!/usr/bin/env bash
# Regenerate the anthropic-parity oracle by running Pi's real
# streamAnthropic/streamSimpleAnthropic (vendored @anthropic-ai/sdk) against
# a scripted local HTTP stub. The oracle pins pi-rs's anthropic protocol
# (crates/pi-rs-ai/src/protocols/anthropic.rs) to the exact requests, event
# sequences, and final messages Pi produces; see tests/anthropic-parity/.
set -euo pipefail
cd "$(dirname "$0")/.."
cases=tests/anthropic-parity/cases.json
oracle=tests/anthropic-parity/oracle.json
if [[ ! -x ref/pi/node_modules/.bin/tsx ]]; then
  nix shell nixpkgs#nodejs_22 --command sh -c 'cd ref/pi && corepack npm ci --ignore-scripts'
fi
nix shell nixpkgs#nodejs_22 --command \
  ref/pi/node_modules/.bin/tsx --tsconfig ref/pi/tsconfig.json \
  tests/anthropic-parity/gen-oracle.ts "$cases" > "$oracle"
echo "wrote $oracle"
