#!/usr/bin/env bash
# Regenerate the session-parity oracle from Pi's real AgentSession +
# SessionManager in ref/pi. The oracle pins pi-rs's product persistence
# policy (crates/pi-rs-app/src/builtins/utils/agent-session.lua over the
# pi.session.* mechanism) to the exact session JSONL entries Pi's coding
# agent writes; see tests/session-parity/.
set -euo pipefail
cd "$(dirname "$0")/.."
cases=tests/session-parity/cases.json
oracle=tests/session-parity/oracle.json
if [[ ! -x ref/pi/node_modules/.bin/tsx ]]; then
  nix shell nixpkgs#nodejs_22 --command sh -c 'cd ref/pi && corepack npm ci --ignore-scripts'
fi
nix shell nixpkgs#nodejs_22 --command \
  ref/pi/node_modules/.bin/tsx --tsconfig ref/pi/tsconfig.json \
  tests/session-parity/gen-oracle.ts "$cases" > "$oracle"
echo "wrote $oracle"
