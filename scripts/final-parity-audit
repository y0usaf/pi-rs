#!/usr/bin/env python3
"""Generate/check the closed Pi v0.79.0 final surface audit.

Reference extraction is explicit (`--update-ref`/`--verify-ref`) and reads the
pinned commit through git. Normal checks consume only checked fixtures.
"""

from __future__ import annotations

import argparse
import copy
import hashlib
import json
import posixpath
import re
import subprocess
import sys
from collections import defaultdict, deque
from pathlib import Path, PurePosixPath

ROOT = Path(__file__).resolve().parent.parent
ORACLE = "Pi v0.79.0 c5582102"
ORACLE_COMMIT = "c5582102f51b143fadc05180e0f8aed050e923b3"
PACKAGES = ("coding-agent", "ai", "agent", "tui")
FIXTURE = ROOT / "tests/final-parity-audit/reference.json"
MANIFEST = ROOT / "tests/final-parity-audit/manifest.json"
OUTPUT = ROOT / "FINAL_PARITY_AUDIT.md"


def canonical(value: object) -> str:
    return json.dumps(value, indent=2, sort_keys=True, ensure_ascii=False) + "\n"


def digest(value: object) -> str:
    raw = json.dumps(value, sort_keys=True, separators=(",", ":"), ensure_ascii=False)
    return hashlib.sha256(raw.encode()).hexdigest()


def git(ref: Path, *args: str, binary: bool = False) -> str | bytes:
    result = subprocess.run(
        ["git", "-C", str(ref), *args],
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if result.returncode:
        raise ValueError(result.stderr.decode(errors="replace").strip())
    return result.stdout if binary else result.stdout.decode()


def source_root(package: str) -> str:
    return f"packages/{package}/src"


def dist_to_source(package: str, target: str) -> str | None:
    target = target.removeprefix("./")
    if target == "package.json":
        return None
    if target.startswith("dist/"):
        target = target[len("dist/") :]
    elif target.startswith("./dist/"):
        target = target[len("./dist/") :]
    if target.endswith(".d.ts"):
        target = target[:-5] + ".ts"
    elif target.endswith(".js"):
        target = target[:-3] + ".ts"
    return f"{source_root(package)}/{target}"


def package_roots(package: str, package_json: dict) -> list[tuple[str, str, str]]:
    roots: list[tuple[str, str, str]] = []
    exports = package_json.get("exports")
    if isinstance(exports, dict):
        for subpath, target in sorted(exports.items()):
            if isinstance(target, dict):
                target = target.get("import") or target.get("default") or target.get("types")
            if not isinstance(target, str):
                continue
            source = dist_to_source(package, target)
            if source:
                roots.append((f"{package}:public:{subpath}", source, "public"))
    else:
        source = dist_to_source(package, str(package_json.get("main", "dist/index.js")))
        if source:
            roots.append((f"{package}:public:.", source, "public"))
    if package == "coding-agent":
        bins = package_json.get("bin", {})
        if isinstance(bins, dict):
            for name, target in sorted(bins.items()):
                source = dist_to_source(package, str(target))
                if source:
                    roots.append((f"{package}:bin:{name}", source, "executable"))
    return roots


FROM_RE = re.compile(
    r"^(?:import|export)\s+(?:type\s+)?[A-Za-z0-9_$*{},\s]+?\sfrom\s*[\"']([^\"']+)[\"']",
    re.MULTILINE,
)
SIDE_EFFECT_RE = re.compile(r"^import\s*[\"']([^\"']+)[\"']", re.MULTILINE)
DYNAMIC_RE = re.compile(r"\bimport\s*\(\s*[\"']([^\"']+)[\"']\s*\)")
NAMED_EXPORT_RE = re.compile(r"\bexport\s+(?:type\s+)?\{([\s\S]*?)\}\s*(?:from\s*[\"']([^\"']+)[\"'])?\s*;", re.MULTILINE)
STAR_EXPORT_RE = re.compile(r"\bexport\s+\*\s+from\s*[\"']([^\"']+)[\"']")
DIRECT_EXPORT_RE = re.compile(
    r"\bexport\s+(?:declare\s+)?(?:abstract\s+)?(?:async\s+)?"
    r"(?:interface|type|class|function|const|let|var|enum|namespace)\s+([A-Za-z_$][\w$]*)"
)
DEFAULT_EXPORT_RE = re.compile(r"\bexport\s+default\b")


def import_specs(source: str) -> list[str]:
    return sorted(set(FROM_RE.findall(source) + SIDE_EFFECT_RE.findall(source) + DYNAMIC_RE.findall(source)))


def resolve_local(path: str, spec: str, paths: set[str], package_exports: dict[str, dict[str, str]]) -> str | None:
    if spec.startswith("."):
        base = PurePosixPath(path).parent.joinpath(spec)
        normalized = posixpath.normpath(str(base))
        candidates = [normalized]
        if normalized.endswith(".js"):
            candidates.append(normalized[:-3] + ".ts")
        if normalized.endswith(".mjs"):
            candidates.append(normalized[:-4] + ".ts")
        if not PurePosixPath(normalized).suffix:
            candidates.extend((normalized + ".ts", normalized + "/index.ts"))
        for candidate in candidates:
            if candidate in paths:
                return candidate
        raise ValueError(f"unresolved local import {path}: {spec}")
    aliases = {
        "@earendil-works/pi-coding-agent": "coding-agent",
        "@earendil-works/pi-ai": "ai",
        "@earendil-works/pi-agent-core": "agent",
        "@earendil-works/pi-tui": "tui",
    }
    for prefix, package in aliases.items():
        if spec == prefix:
            return package_exports[package].get(".")
        if spec.startswith(prefix + "/"):
            return package_exports[package].get("./" + spec[len(prefix) + 1 :])
    return None


def named_exports(source: str) -> list[str]:
    names = set(DIRECT_EXPORT_RE.findall(source))
    if DEFAULT_EXPORT_RE.search(source):
        names.add("default")
    for body, _ in NAMED_EXPORT_RE.findall(source):
        for raw in body.split(","):
            item = re.sub(r"\s+", " ", raw.strip()).removeprefix("type ").strip()
            if not item:
                continue
            match = re.match(r"([A-Za-z_$][\w$]*)(?:\s+as\s+([A-Za-z_$][\w$]*))?$", item)
            if match:
                names.add(match.group(2) or match.group(1))
    return sorted(names)


def extract_reference(ref: Path) -> dict:
    resolved = str(git(ref, "rev-parse", ORACLE_COMMIT)).strip()
    if resolved != ORACLE_COMMIT:
        raise ValueError(f"reference does not contain pinned commit {ORACLE_COMMIT}")
    prefixes = [source_root(package) for package in PACKAGES]
    listed = git(ref, "ls-tree", "-r", "--name-only", ORACLE_COMMIT, "--", *prefixes)
    paths = sorted(path for path in str(listed).splitlines() if path)
    if not paths:
        raise ValueError("pinned reference source tree is empty")
    contents = {path: bytes(git(ref, "show", f"{ORACLE_COMMIT}:{path}", binary=True)) for path in paths}
    path_set = set(paths)

    package_jsons: dict[str, dict] = {}
    roots: list[dict[str, str]] = []
    package_exports: dict[str, dict[str, str]] = {}
    for package in PACKAGES:
        package_path = f"packages/{package}/package.json"
        raw = bytes(git(ref, "show", f"{ORACLE_COMMIT}:{package_path}", binary=True))
        package_json = json.loads(raw)
        package_jsons[package] = package_json
        exports: dict[str, str] = {}
        raw_exports = package_json.get("exports")
        if isinstance(raw_exports, dict):
            for subpath, target in raw_exports.items():
                if isinstance(target, dict):
                    target = target.get("import") or target.get("default") or target.get("types")
                if isinstance(target, str):
                    source = dist_to_source(package, target)
                    if source:
                        exports[subpath] = source
        else:
            source = dist_to_source(package, str(package_json.get("main", "dist/index.js")))
            if source:
                exports["."] = source
        package_exports[package] = exports
        for label, path, kind in package_roots(package, package_json):
            if path not in path_set:
                raise ValueError(f"missing public/executable root {label}: {path}")
            roots.append({"label": label, "path": path, "kind": kind})

    dependencies: dict[str, list[str]] = {}
    externals: dict[str, list[str]] = {}
    exports_by_file: dict[str, list[str]] = {}
    for path in paths:
        if not path.endswith(".ts"):
            dependencies[path] = []
            externals[path] = []
            exports_by_file[path] = []
            continue
        source = contents[path].decode("utf-8")
        local: list[str] = []
        external: list[str] = []
        for spec in import_specs(source):
            resolved_path = resolve_local(path, spec, path_set, package_exports)
            if resolved_path:
                local.append(resolved_path)
            else:
                external.append(spec)
        dependencies[path] = sorted(set(local))
        externals[path] = sorted(set(external))
        exports_by_file[path] = named_exports(source)

    reached_by: dict[str, set[str]] = defaultdict(set)
    for root in roots:
        queue = deque([root["path"]])
        while queue:
            path = queue.popleft()
            if root["label"] in reached_by[path]:
                continue
            reached_by[path].add(root["label"])
            queue.extend(dependencies[path])

    export_cache: dict[str, dict[str, str]] = {}

    def public_exports(path: str, stack: frozenset[str] = frozenset()) -> dict[str, str]:
        if path in export_cache:
            return export_cache[path]
        if path in stack or not path.endswith(".ts"):
            return {}
        source = contents[path].decode("utf-8")
        result = {name: path for name in exports_by_file[path]}
        next_stack = stack | {path}
        for spec in STAR_EXPORT_RE.findall(source):
            target = resolve_local(path, spec, path_set, package_exports)
            if target:
                for name, origin in public_exports(target, next_stack).items():
                    if name != "default":
                        result.setdefault(name, origin)
        for body, spec in NAMED_EXPORT_RE.findall(source):
            if not spec:
                continue
            target = resolve_local(path, spec, path_set, package_exports)
            for raw in body.split(","):
                item = re.sub(r"\s+", " ", raw.strip()).removeprefix("type ").strip()
                match = re.match(r"([A-Za-z_$][\w$]*)(?:\s+as\s+([A-Za-z_$][\w$]*))?$", item)
                if match:
                    public_name = match.group(2) or match.group(1)
                    result[public_name] = target or path
        export_cache[path] = result
        return result

    public_rows: list[dict[str, str]] = []
    for root in roots:
        if root["kind"] != "public":
            continue
        for symbol, origin in sorted(public_exports(root["path"]).items()):
            public_rows.append({"root": root["label"], "symbol": symbol, "origin": origin})

    files = []
    for path in paths:
        files.append(
            {
                "path": path,
                "sha256": hashlib.sha256(contents[path]).hexdigest(),
                "bytes": len(contents[path]),
                "imports": dependencies[path],
                "external_imports": externals[path],
                "exports": exports_by_file[path],
                "reached_by": sorted(reached_by[path]),
            }
        )
    return {
        "schema": 1,
        "oracle": ORACLE,
        "commit": ORACLE_COMMIT,
        "scope": {
            "packages": list(PACKAGES),
            "rule": "all package src files; coding-agent public/bin roots; support-package public roots",
        },
        "roots": sorted(roots, key=lambda row: row["label"]),
        "files": files,
        "public_exports": public_rows,
    }


def load_json(path: Path) -> dict:
    try:
        value = json.loads(path.read_text())
    except OSError as error:
        raise ValueError(f"cannot read {path.relative_to(ROOT)}: {error}") from error
    except json.JSONDecodeError as error:
        raise ValueError(f"invalid JSON in {path.relative_to(ROOT)}: {error}") from error
    if not isinstance(value, dict):
        raise ValueError(f"{path.relative_to(ROOT)}: expected JSON object")
    return value


def validate(reference: dict, manifest: dict, *, check_evidence: bool = True) -> dict[str, dict]:
    if reference.get("oracle") != ORACLE or reference.get("commit") != ORACLE_COMMIT:
        raise ValueError("reference fixture has the wrong oracle/commit")
    files = reference.get("files")
    if not isinstance(files, list) or not files:
        raise ValueError("reference fixture has no files")
    paths = [row.get("path") for row in files]
    if any(not isinstance(path, str) or not path for path in paths):
        raise ValueError("reference fixture has an invalid file path")
    if len(paths) != len(set(paths)):
        raise ValueError("reference fixture has duplicate file paths")
    if paths != sorted(paths):
        raise ValueError("reference fixture file paths are not sorted")
    if manifest.get("schema") != 1 or manifest.get("oracle") != ORACLE:
        raise ValueError("manifest has the wrong schema/oracle")
    expected_digest = digest(reference)
    if manifest.get("reference_sha256") != expected_digest:
        raise ValueError(
            "manifest reference_sha256 is stale; regenerate/review the pinned reference fixture"
        )
    differences = manifest.get("differences")
    if not isinstance(differences, list) or [row.get("number") for row in differences] != list(range(1, 7)):
        raise ValueError("manifest must classify each DESIGN difference 1-6 exactly once")
    for row in differences:
        number = row["number"]
        status = row.get("status")
        owner = str(row.get("owner", "")).strip()
        finding = str(row.get("finding", "")).strip()
        evidence = row.get("evidence")
        if status not in {"bounded", "open"} or not owner or not finding:
            raise ValueError(f"DESIGN difference {number}: status, owner, and finding are required")
        if status == "bounded" and owner != f"DESIGN difference {number}":
            raise ValueError(f"DESIGN difference {number}: bounded owner is invalid")
        if status == "open" and not re.fullmatch(r"PLAN (?:9(?:\.[0-9]+[ab]?)?|11)", owner):
            raise ValueError(f"DESIGN difference {number}: open owner must name PLAN 9.x/11")
        if not isinstance(evidence, list) or not evidence:
            raise ValueError(f"DESIGN difference {number}: evidence is required")
        if check_evidence:
            for item in evidence:
                if not isinstance(item, dict) or set(item) - {"path", "contains"}:
                    raise ValueError(f"DESIGN difference {number}: invalid evidence entry")
                evidence_path = ROOT / str(item.get("path", ""))
                if not evidence_path.is_file():
                    raise ValueError(f"DESIGN difference {number}: missing evidence {evidence_path.relative_to(ROOT)}")
                needle = item.get("contains")
                if needle is not None and str(needle) not in evidence_path.read_text(errors="replace"):
                    raise ValueError(f"DESIGN difference {number}: stale evidence anchor {needle!r}")
    groups = manifest.get("groups")
    if not isinstance(groups, list) or not groups:
        raise ValueError("manifest groups must be a non-empty list")
    allowed = {"parity", "open", "design", "out-of-scope"}
    classified: dict[str, dict] = {}
    group_ids: set[str] = set()
    for group in groups:
        if not isinstance(group, dict):
            raise ValueError("manifest group must be an object")
        group_id = str(group.get("id", ""))
        if not group_id or group_id in group_ids:
            raise ValueError(f"missing/duplicate manifest group id {group_id!r}")
        group_ids.add(group_id)
        status = group.get("status")
        if status not in allowed:
            raise ValueError(f"{group_id}: invalid status {status!r}")
        owner = str(group.get("owner", "")).strip()
        rationale = str(group.get("rationale", "")).strip()
        evidence = group.get("evidence")
        refs = group.get("refs")
        if not owner or not rationale or not isinstance(evidence, list) or not evidence:
            raise ValueError(f"{group_id}: owner, rationale, and evidence are required")
        if status == "open" and not re.fullmatch(r"PLAN (?:8|9(?:\.[0-9]+[ab]?)?|10|11)", owner):
            raise ValueError(f"{group_id}: open owner must name a PLAN 8/9.x/10/11 item")
        if status == "design" and not re.fullmatch(r"DESIGN difference [1-6]", owner):
            raise ValueError(f"{group_id}: design owner must name an exhaustive DESIGN difference")
        if status == "out-of-scope" and owner != "DESIGN product boundary":
            raise ValueError(f"{group_id}: out-of-scope owner must be DESIGN product boundary")
        if not isinstance(refs, list) or not refs:
            raise ValueError(f"{group_id}: refs must be a non-empty list")
        for ref in refs:
            if not isinstance(ref, str) or not ref:
                raise ValueError(f"{group_id}: invalid reference row")
            if ref in classified:
                raise ValueError(f"{ref}: classified by both {classified[ref]['id']} and {group_id}")
            classified[ref] = group
        if check_evidence:
            for item in evidence:
                if not isinstance(item, dict) or set(item) - {"path", "contains"}:
                    raise ValueError(f"{group_id}: invalid evidence entry")
                evidence_path = ROOT / str(item.get("path", ""))
                if not evidence_path.is_file():
                    raise ValueError(f"{group_id}: missing evidence {evidence_path.relative_to(ROOT)}")
                needle = item.get("contains")
                if needle is not None and str(needle) not in evidence_path.read_text(errors="replace"):
                    raise ValueError(
                        f"{group_id}: stale evidence anchor {evidence_path.relative_to(ROOT)}: {needle!r}"
                    )
    expected = set(paths)
    actual = set(classified)
    if expected != actual:
        missing = sorted(expected - actual)
        stale = sorted(actual - expected)
        raise ValueError(f"classification closure failed: missing={missing}, stale={stale}")
    return classified


def render(reference: dict, manifest: dict, classified: dict[str, dict]) -> str:
    files = reference["files"]
    public = reference["public_exports"]
    package_counts: dict[str, int] = defaultdict(int)
    status_counts: dict[str, int] = defaultdict(int)
    public_status: dict[str, int] = defaultdict(int)
    unreachable = 0
    for row in files:
        package = row["path"].split("/")[1]
        package_counts[package] += 1
        status_counts[classified[row["path"]]["status"]] += 1
        if not row["reached_by"]:
            unreachable += 1
    for row in public:
        public_status[classified[row["origin"]]["status"]] += 1
    lines = [
        "# Final parity audit",
        "",
        f"Oracle: `{ORACLE}` (`{ORACLE_COMMIT}`). Generated by",
        "`scripts/final-parity-audit`; edit the checked manifest, then regenerate.",
        "Normal checks are offline: the checked reference graph carries pinned hashes;",
        "`--verify-ref PATH` mechanically reproduces it from the vendored git revision.",
        "",
        "## Scope and closure",
        "",
        "- Every file under the four pinned `src/` trees is hashed and classified.",
        "- Public exports are resolved from package entrypoints; executable and import",
        "  reachability is traversed across local and Pi-package imports.",
        "- Missing, stale, duplicate, invalid, or evidence-less classifications fail closed.",
        "- `parity` means cited differential/public evidence exists; it is not inferred",
        "  from a similarly named Rust module. `open` rows remain release blockers.",
        "- `design` rows are authorized only by the exhaustive difference list;",
        "  `out-of-scope` rows cite the product boundary rather than pretending parity.",
        "",
        f"Files: **{len(files)}** ({', '.join(f'{key}={package_counts[key]}' for key in sorted(package_counts))}); "
        f"public export rows: **{len(public)}**; source files with no public/bin reachability: **{unreachable}**.",
        "",
        "| Classification | Source files | Public exports |",
        "|---|---:|---:|",
    ]
    for status in ("parity", "open", "design", "out-of-scope"):
        lines.append(f"| `{status}` | {status_counts[status]} | {public_status[status]} |")
    lines += [
        "",
        "> This audit intentionally does **not** close PLAN 11: open prerequisite rows",
        "> remain in PLAN 8/9/10, and PLAN 11 retains the final live side-by-side gate.",
        "",
        "## Exhaustive DESIGN differences",
        "",
        "| Difference | Audit status | Owner | Width finding |",
        "|---:|---|---|---|",
    ]
    for row in manifest["differences"]:
        finding = str(row["finding"]).replace("|", "\\|")
        lines.append(f"| {row['number']} | `{row['status']}` | {row['owner']} | {finding} |")
    lines += [
        "",
        "## Classified source groups",
        "",
        "| Group | Status | Owner | Rows | Evidence / finding |",
        "|---|---|---|---:|---|",
    ]
    for group in manifest["groups"]:
        evidence = ", ".join(f"`{item['path']}`" for item in group["evidence"])
        rationale = str(group["rationale"]).replace("|", "\\|")
        lines.append(
            f"| `{group['id']}` | `{group['status']}` | {group['owner']} | {len(group['refs'])} | "
            f"{rationale} Evidence: {evidence}. |"
        )
    lines += ["", "## Open gaps", ""]
    open_groups = [group for group in manifest["groups"] if group["status"] == "open"]
    if not open_groups:
        lines.append("None.")
    for group in open_groups:
        lines += [
            f"### {group['owner']} — `{group['id']}`",
            "",
            group["rationale"],
            "",
            f"Reference rows ({len(group['refs'])}):",
            "",
        ]
        lines.extend(f"- `{path}`" for path in group["refs"])
        lines.append("")
    lines += ["## Public entrypoints", ""]
    by_root: dict[str, list[dict]] = defaultdict(list)
    for row in public:
        by_root[row["root"]].append(row)
    for root in reference["roots"]:
        if root["kind"] != "public":
            continue
        rows = by_root[root["label"]]
        statuses = defaultdict(int)
        for row in rows:
            statuses[classified[row["origin"]]["status"]] += 1
        summary = ", ".join(f"{key}={statuses[key]}" for key in sorted(statuses))
        lines.append(f"- `{root['label']}` → `{root['path']}`: {len(rows)} exports ({summary})")
    lines.append("")
    return "\n".join(lines)


def self_test(reference: dict, manifest: dict) -> None:
    validate(reference, manifest)

    missing = copy.deepcopy(manifest)
    missing["groups"][0]["refs"].pop()
    expect_failure(reference, missing, "missing=")

    duplicate = copy.deepcopy(manifest)
    duplicate["groups"][1]["refs"].append(duplicate["groups"][0]["refs"][0])
    expect_failure(reference, duplicate, "classified by both")

    stale = copy.deepcopy(manifest)
    stale["groups"][0]["refs"].append("packages/coding-agent/src/not-real.ts")
    expect_failure(reference, stale, "stale=")

    invalid = copy.deepcopy(manifest)
    invalid["groups"][0]["status"] = "approximately-done"
    expect_failure(reference, invalid, "invalid status")

    missing_difference = copy.deepcopy(manifest)
    missing_difference["differences"].pop()
    expect_failure(reference, missing_difference, "classify each DESIGN difference")

    stale_reference = copy.deepcopy(manifest)
    stale_reference["reference_sha256"] = "0" * 64
    expect_failure(reference, stale_reference, "reference_sha256 is stale")


def expect_failure(reference: dict, manifest: dict, needle: str) -> None:
    try:
        validate(reference, manifest, check_evidence=False)
    except ValueError as error:
        if needle not in str(error):
            raise ValueError(f"self-test expected {needle!r}, got {error}") from error
        return
    raise ValueError(f"self-test expected failure containing {needle!r}")


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--check", action="store_true")
    parser.add_argument("--self-test", action="store_true")
    parser.add_argument("--update-ref", type=Path, metavar="PATH")
    parser.add_argument("--verify-ref", type=Path, metavar="PATH")
    args = parser.parse_args()
    try:
        if args.update_ref:
            reference = extract_reference(args.update_ref)
            FIXTURE.parent.mkdir(parents=True, exist_ok=True)
            FIXTURE.write_text(canonical(reference))
            print(f"wrote {FIXTURE.relative_to(ROOT)} ({len(reference['files'])} source rows)")
            return 0
        reference = load_json(FIXTURE)
        if args.verify_ref:
            actual = extract_reference(args.verify_ref)
            if actual != reference:
                raise ValueError("checked reference fixture differs from pinned git extraction")
            print("checked reference fixture matches pinned git extraction")
            return 0
        manifest = load_json(MANIFEST)
        classified = validate(reference, manifest)
        if args.self_test:
            self_test(reference, manifest)
            print("final parity audit fail-closed self-tests passed")
            return 0
        generated = render(reference, manifest, classified)
        if args.check:
            current = OUTPUT.read_text() if OUTPUT.exists() else ""
            if current != generated:
                raise ValueError("FINAL_PARITY_AUDIT.md is stale; run scripts/final-parity-audit")
            print(
                f"final parity audit is current: {len(reference['files'])} files, "
                f"{len(reference['public_exports'])} public exports"
            )
            return 0
        OUTPUT.write_text(generated)
        print(f"wrote {OUTPUT.relative_to(ROOT)}")
        return 0
    except (OSError, ValueError, subprocess.SubprocessError) as error:
        print(f"final parity audit: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
