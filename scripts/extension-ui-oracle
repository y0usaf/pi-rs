#!/usr/bin/env bash
# Regenerate PLAN 9.1's queued UI-action oracle from Pi v0.79.0 examples.
set -euo pipefail
cd "$(dirname "$0")/.."
oracle=tests/extension-ui-parity/oracle.json
if [[ ! -x ref/pi/node_modules/.bin/tsx ]]; then
  nix shell nixpkgs#nodejs_22 --command sh -c 'cd ref/pi && corepack npm ci --ignore-scripts'
fi
mkdir -p "$(dirname "$oracle")"
env -u PI_PACKAGE_DIR FORCE_COLOR=3 EXTENSION_UI_ACTIONS_ONLY=1 \
  nix shell nixpkgs#nodejs_22 --command \
  ref/pi/node_modules/.bin/tsx --tsconfig ref/pi/tsconfig.json \
  tests/ui-parity/pi-extension-ui-turn.ts tests/ui-parity/extension-ui-turn.json > "$oracle"
echo "wrote $oracle"
