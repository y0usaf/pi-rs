#!/usr/bin/env python3
"""Generate/check the pinned pi-flake external-extension capability inventory."""

from __future__ import annotations

import argparse
import hashlib
import json
import re
import shutil
import subprocess
import sys
from collections import defaultdict
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
BASE = ROOT / "tests/external-extension-inventory"
FIXTURES = BASE / "fixtures"
PROVENANCE = BASE / "provenance.json"
MANIFEST = BASE / "manifest.json"
OUTPUT = ROOT / "EXTERNAL_EXTENSION_INVENTORY.md"
REVISION = "94694da7321ce74aa7b82c13db7e60e28c0caba6"
REPOSITORY = "https://github.com/y0usaf/pi-flake"
EXTENSIONS_TREE = "c4a04dfe88314b5e48ebb200ccfd546645c3af9e"
FIXTURE_DIGEST = "7bf4166a0b4d3e2a7db7dd57faa381e04996849c464dcef0a34c3e93445856d2"
SELECTION = "package.json plus production TypeScript; tests/ and scripts/ excluded"
EXPECTED_EXTENSIONS = {
    "earendil_pi-review",
    "pi-codex-fast",
    "pi-compact",
    "pi-context-janitor",
    "pi-gecko-websearch",
    "pi-hashline",
    "pi-minimal-editor",
    "pi-morph",
    "pi-pomodoro",
    "pi-rlm",
    "pi-rtk",
    "pi-tool-management",
    "pi-webfetch",
    "pi-working-indicator",
    "sting8k_pi-vcc",
}
CATEGORIES = (
    "pi_api",
    "package_imports",
    "node_ambient",
    "lifetimes",
    "system_needs",
    "private_pi",
)
CONTEXT_ROOTS = {
    "abort", "compact", "cwd", "getContextUsage", "getSystemPrompt",
    "getSystemPromptOptions", "hasPendingMessages", "hasUI", "isIdle",
    "isProjectTrusted", "mode", "model", "modelRegistry", "navigateTree",
    "newSession", "reload", "sessionManager", "shutdown", "signal",
    "switchSession", "ui", "waitForIdle",
}
PUBLIC_PI_CONCRETE = {
    "BorderedLoader",
    "CustomEditor",
    "DynamicBorder",
}


def is_private_pi_import(symbol: str, type_only: bool) -> bool:
    if type_only or symbol in PUBLIC_PI_CONCRETE:
        return False
    return symbol.endswith(("Component", "Manager")) or symbol in {
        "DefaultResourceLoader",
        "createAgentSession",
    }

IMPORT_RE = re.compile(
    r"(?:^|\n)\s*import\s+(?!\()(?:(?P<clause>[\s\S]*?)\s+from\s+)?[\"'](?P<module>[^\"']+)[\"']\s*;?",
    re.MULTILINE,
)
DYNAMIC_IMPORT_RE = re.compile(r"\bimport\(\s*[\"']([^\"']+)[\"']\s*\)")


def sha256(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def records_digest(records: dict[str, dict[str, str]]) -> str:
    entries = [
        f"{extension}/{relative}\0{digest}"
        for extension, files in sorted(records.items())
        for relative, digest in sorted(files.items())
    ]
    return sha256("\n".join(entries).encode())


def git(repo: Path, *args: str, binary: bool = False) -> bytes | str:
    result = subprocess.run(
        ["git", "-C", str(repo), *args],
        check=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    return result.stdout if binary else result.stdout.decode()


def selected_paths(repo: Path) -> list[str]:
    paths = git(repo, "ls-tree", "-r", "--name-only", REVISION, "extensions").splitlines()
    selected = []
    for path in paths:
        if path.endswith("/package.json"):
            selected.append(path)
        elif path.endswith(".ts") and "/tests/" not in path and "/scripts/" not in path:
            selected.append(path)
    return sorted(selected)


def refresh_fixtures(repo: Path) -> None:
    resolved = git(repo, "rev-parse", f"{REVISION}^{{commit}}").strip()
    if resolved != REVISION:
        raise ValueError(f"pi-flake revision mismatch: expected {REVISION}, got {resolved}")
    paths = selected_paths(repo)
    extensions = {path.split("/", 2)[1] for path in paths}
    if extensions != EXPECTED_EXTENSIONS:
        raise ValueError(f"extension set mismatch: expected {sorted(EXPECTED_EXTENSIONS)}, got {sorted(extensions)}")
    if FIXTURES.exists():
        shutil.rmtree(FIXTURES)
    records: dict[str, dict[str, str]] = defaultdict(dict)
    for source_path in paths:
        _, extension, relative = source_path.split("/", 2)
        data = git(repo, "show", f"{REVISION}:{source_path}", binary=True)
        destination = FIXTURES / extension / relative
        destination.parent.mkdir(parents=True, exist_ok=True)
        destination.write_bytes(data)
        records[extension][relative] = sha256(data)
    tree = git(repo, "rev-parse", f"{REVISION}:extensions").strip()
    normalized_records = {
        name: dict(sorted(files.items())) for name, files in sorted(records.items())
    }
    digest = records_digest(normalized_records)
    if tree != EXTENSIONS_TREE or digest != FIXTURE_DIGEST:
        raise ValueError(
            f"pinned source mismatch: tree={tree}, fixture_digest={digest}"
        )
    provenance = {
        "schema_version": 1,
        "source_repository": REPOSITORY,
        "revision": REVISION,
        "extensions_tree": tree,
        "selection": SELECTION,
        "fixture_digest": digest,
        "extension_count": len(records),
        "files": normalized_records,
    }
    PROVENANCE.parent.mkdir(parents=True, exist_ok=True)
    PROVENANCE.write_text(json.dumps(provenance, indent=2, sort_keys=False) + "\n")


def load_and_validate_fixtures() -> tuple[dict, dict[str, list[Path]]]:
    provenance = json.loads(PROVENANCE.read_text())
    expected_header = {
        "schema_version": 1,
        "source_repository": REPOSITORY,
        "revision": REVISION,
        "extensions_tree": EXTENSIONS_TREE,
        "selection": SELECTION,
        "fixture_digest": FIXTURE_DIGEST,
        "extension_count": 15,
    }
    for key, expected in expected_header.items():
        if provenance.get(key) != expected:
            raise ValueError(f"provenance {key} must be {expected!r}")
    files = provenance.get("files")
    if not isinstance(files, dict) or set(files) != EXPECTED_EXTENSIONS:
        raise ValueError("provenance must contain exactly the 15 pinned extensions")
    if records_digest(files) != FIXTURE_DIGEST:
        raise ValueError("provenance file inventory digest differs from pinned fixture")
    actual_paths = {
        str(path.relative_to(FIXTURES))
        for path in FIXTURES.rglob("*")
        if path.is_file()
    }
    expected_paths: set[str] = set()
    sources: dict[str, list[Path]] = {}
    for extension, records in files.items():
        if not isinstance(records, dict) or "package.json" not in records:
            raise ValueError(f"{extension}: package.json missing from provenance")
        source_paths = []
        for relative, expected_hash in records.items():
            path = FIXTURES / extension / relative
            fixture_relative = f"{extension}/{relative}"
            expected_paths.add(fixture_relative)
            if not path.is_file():
                raise ValueError(f"fixture missing: {fixture_relative}")
            actual_hash = sha256(path.read_bytes())
            if actual_hash != expected_hash:
                raise ValueError(f"fixture hash mismatch: {fixture_relative}")
            if path.suffix == ".ts":
                source_paths.append(path)
        if not source_paths:
            raise ValueError(f"{extension}: no production TypeScript fixture")
        sources[extension] = sorted(source_paths)
    if actual_paths != expected_paths:
        missing = sorted(expected_paths - actual_paths)
        extra = sorted(actual_paths - expected_paths)
        raise ValueError(f"fixture file set differs: missing={missing}, extra={extra}")
    return provenance, sources


def parse_import_clause(clause: str | None) -> list[tuple[str, str, bool]]:
    if clause is None:
        return [("side-effect", "", False)]
    clause = clause.strip()
    whole_type = clause.startswith("type ")
    if whole_type:
        clause = clause[5:].strip()
    result: list[tuple[str, str, bool]] = []
    named = re.search(r"\{([\s\S]*?)\}", clause)
    if named:
        for part in named.group(1).split(","):
            part = part.strip()
            if not part:
                continue
            item_type = whole_type or part.startswith("type ")
            if part.startswith("type "):
                part = part[5:].strip()
            bits = re.split(r"\s+as\s+", part)
            result.append((bits[0].strip(), bits[-1].strip(), item_type))
        clause = clause[: named.start()] + clause[named.end() :]
    namespace = re.search(r"\*\s+as\s+([A-Za-z_$][\w$]*)", clause)
    if namespace:
        result.append(("*", namespace.group(1), whole_type))
        clause = clause[: namespace.start()] + clause[namespace.end() :]
    default = clause.strip().strip(",").strip()
    if default:
        match = re.match(r"([A-Za-z_$][\w$]*)", default)
        if match:
            result.append(("default", match.group(1), whole_type))
    return result


def code_only(source: str) -> str:
    """Mask comments and literals while preserving line structure for lexical scans."""
    pattern = re.compile(
        r'"(?:\\.|[^"\\\n])*"|\'(?:\\.|[^\'\\\n])*\'|//[^\n]*|/\*[\s\S]*?\*/'
    )

    def mask(match: re.Match[str]) -> str:
        return "".join("\n" if char == "\n" else " " for char in match.group(0))

    return pattern.sub(mask, source)


def add(rows: dict[str, dict[str, set[str]]], category: str, item: str, extension: str) -> None:
    rows[category][item].add(extension)


def extract(sources: dict[str, list[Path]]) -> dict[str, dict[str, set[str]]]:
    rows: dict[str, dict[str, set[str]]] = {category: defaultdict(set) for category in CATEGORIES}
    for extension, paths in sources.items():
        for path in paths:
            text = path.read_text()
            code = code_only(text)
            bindings: list[tuple[str, str, str, bool]] = []
            for match in IMPORT_RE.finditer(text):
                module = match.group("module")
                if module.startswith(".") or module.startswith("/"):
                    continue
                for imported, local, type_only in parse_import_clause(match.group("clause")):
                    marker = f"type:{imported}" if type_only else imported
                    add(rows, "package_imports", f"{module}#{marker}", extension)
                    bindings.append((module, imported, local, type_only))
                    if (
                        module == "@earendil-works/pi-coding-agent"
                        and is_private_pi_import(imported, type_only)
                    ):
                        add(rows, "private_pi", imported, extension)
            for module in DYNAMIC_IMPORT_RE.findall(text):
                if not module.startswith(".") and not module.startswith("/"):
                    add(rows, "package_imports", f"{module}#dynamic", extension)

            for member in re.findall(r"\bpi\.([A-Za-z_$][\w$]*)", code):
                add(rows, "pi_api", f"ExtensionAPI.{member}", extension)
            for event in re.findall(r"\bpi\.on\(\s*[\"']([^\"']+)[\"']", text):
                add(rows, "pi_api", f"event.{event}", extension)
            for member in re.findall(r"\bctx\.([A-Za-z_$][\w$]*)", code):
                if member in CONTEXT_ROOTS:
                    add(rows, "pi_api", f"ExtensionContext.{member}", extension)
            for member in re.findall(r"\bctx\.ui\.([A-Za-z_$][\w$]*)", code):
                add(rows, "pi_api", f"ExtensionUI.{member}", extension)
            for member in re.findall(r"\bctx\.sessionManager\.([A-Za-z_$][\w$]*)", code):
                add(rows, "pi_api", f"SessionManager.{member}", extension)
            for member in re.findall(r"\bctx\.modelRegistry\.([A-Za-z_$][\w$]*)", code):
                add(rows, "pi_api", f"ModelRegistry.{member}", extension)

            ambient_patterns = {
                "process.cwd": r"\bprocess\.cwd\s*\(",
                "process.platform": r"\bprocess\.platform\b",
                "process.argv": r"\bprocess\.argv\b",
                "fetch": r"\bfetch\s*\(",
                "AbortController": r"\bAbortController\b",
                "AbortSignal": r"\bAbortSignal\b",
                "URL": r"\bnew\s+URL\s*\(",
                "Bun.hash.xxHash32": r"\bBun\?\.hash\?\.xxHash32\b",
            }
            for item, pattern in ambient_patterns.items():
                if re.search(pattern, code):
                    add(rows, "node_ambient", item, extension)
            for name in re.findall(r"\bprocess\.env\.([A-Za-z_$][\w$]*)", code):
                add(rows, "node_ambient", f"process.env.{name}", extension)
            if re.search(r"\bprocess\.env\s*\[", code):
                add(rows, "node_ambient", "process.env[dynamic]", extension)
            for method in re.findall(r"\bBuffer\.([A-Za-z_$][\w$]*)", code):
                add(rows, "node_ambient", f"Buffer.{method}", extension)
            for timer in ("setTimeout", "clearTimeout", "setInterval", "clearInterval"):
                if re.search(rf"\b{timer}\s*\(", code):
                    add(rows, "node_ambient", timer, extension)
                    add(rows, "lifetimes", f"timer.{timer}", extension)

            normalized_modules = {
                "fs": "filesystem",
                "fs/promises": "filesystem",
                "child_process": "process",
                "net": "socket",
                "crypto": "crypto",
            }
            for module, imported, local, type_only in bindings:
                normalized = module.removeprefix("node:")
                need = normalized_modules.get(normalized)
                if not need or type_only:
                    continue
                if imported == "*" or (normalized == "fs" and imported == "promises"):
                    for method in re.findall(rf"\b{re.escape(local)}\.([A-Za-z_$][\w$]*)", code):
                        add(rows, "system_needs", f"{need}.{method}", extension)
                elif imported != "side-effect":
                    add(rows, "system_needs", f"{need}.{imported}", extension)
            if re.search(r"\bpi\.exec\s*\(", code):
                add(rows, "system_needs", "process.pi.exec", extension)
            if re.search(r"\bfetch\s*\(", code):
                add(rows, "system_needs", "network.http", extension)
            if re.search(r"\bprocess\.env\b", code):
                add(rows, "system_needs", "process.environment", extension)
            has_child_process = any(
                module.removeprefix("node:") == "child_process" and not type_only
                for module, _imported, _local, type_only in bindings
            )
            if has_child_process and re.search(r"\bstdio\s*:|\.(?:stdin|stdout|stderr)\b", code):
                add(rows, "system_needs", "process.stdio_pipes", extension)
            if has_child_process and re.search(r"\.kill\s*\(", code):
                add(rows, "system_needs", "process.kill", extension)
            if re.search(r"\bcreateHash\s*\(\s*[\"']sha256[\"']", text):
                add(rows, "system_needs", "crypto.sha256", extension)
            if re.search(r"\bBun\?\.hash\?\.xxHash32\b", code):
                add(rows, "system_needs", "crypto.xxHash32", extension)

        lifetime_items = rows["lifetimes"]
        has_timer_or_resource = any(extension in owners for owners in lifetime_items.values())
        system = rows["system_needs"]
        if any(extension in owners for item, owners in system.items() if item.startswith("process.spawn")):
            add(rows, "lifetimes", "resource.child_process", extension)
        if any(extension in owners for item, owners in system.items() if item.startswith("socket.")):
            add(rows, "lifetimes", "resource.tcp_socket", extension)
        if any(extension in owners for item, owners in system.items() if item == "filesystem.watchFile"):
            add(rows, "lifetimes", "resource.file_watcher", extension)
        has_resource = any(
            extension in owners and item.startswith("resource.")
            for item, owners in rows["lifetimes"].items()
        )
        events = rows["pi_api"]
        if (has_timer_or_resource or has_resource) and extension in events.get("event.session_shutdown", set()):
            add(rows, "lifetimes", "cleanup.session_shutdown", extension)
    return rows


def validate_manifest(rows: dict[str, dict[str, set[str]]], manifest: dict) -> dict[str, dict[str, dict]]:
    if manifest.get("oracle") != f"pi-flake {REVISION}":
        raise ValueError(f"manifest oracle must be pi-flake {REVISION}")
    categories = manifest.get("categories")
    if not isinstance(categories, dict) or set(categories) != set(CATEGORIES):
        raise ValueError(f"manifest categories must be {list(CATEGORIES)}")
    allowed = re.compile(r"^(implemented|planned 9\.(?:[2-9]|10|11)|DESIGN exception [0-9]+)$")
    classified: dict[str, dict[str, dict]] = {}
    for category in CATEGORIES:
        groups = categories[category]
        if not isinstance(groups, list):
            raise ValueError(f"{category}: expected status groups")
        found: dict[str, dict] = {}
        for group in groups:
            status = str(group.get("status", ""))
            evidence = str(group.get("evidence", "")).strip()
            items = group.get("items")
            if not allowed.match(status):
                raise ValueError(f"{category}: invalid status {status!r}")
            if not evidence:
                raise ValueError(f"{category}: evidence/target is required")
            if not isinstance(items, list) or not items:
                raise ValueError(f"{category}: each group needs non-empty items")
            for item in items:
                if item in found:
                    raise ValueError(f"{category}.{item}: classified more than once")
                found[item] = {"status": status, "evidence": evidence}
        expected = set(rows[category])
        actual = set(found)
        if actual != expected:
            missing = sorted(expected - actual)
            stale = sorted(actual - expected)
            raise ValueError(f"{category}: missing={missing}, stale={stale}")
        classified[category] = found
    return classified


def render(provenance: dict, rows: dict[str, dict[str, set[str]]], classified: dict[str, dict[str, dict]]) -> str:
    titles = {
        "pi_api": "Pi API use",
        "package_imports": "Package imports",
        "node_ambient": "Node ambient capabilities",
        "lifetimes": "Timers and background lifetimes",
        "system_needs": "Process / socket / filesystem / crypto needs",
        "private_pi": "Private Pi implementation dependencies",
    }
    lines = [
        "# External extension capability inventory",
        "",
        f"Generated from checked fixtures for all 15 extensions at `pi-flake` `{REVISION}`",
        f"(`extensions` tree `{provenance['extensions_tree']}`). The source fixture hashes live in",
        "`tests/external-extension-inventory/provenance.json`; normal generation/checking is offline.",
        "",
        "Statuses are closed: `implemented`, a specific `planned 9.x` rung, or an explicit DESIGN exception.",
        "",
    ]
    for category in CATEGORIES:
        lines.extend([
            f"## {titles[category]}",
            "",
            "| Capability | Extensions | Status | Evidence / target |",
            "|---|---|---|---|",
        ])
        for item in sorted(rows[category]):
            owners = ", ".join(f"`{name}`" for name in sorted(rows[category][item]))
            record = classified[category][item]
            escaped = item.replace("|", "\\|")
            evidence = record["evidence"].replace("|", "\\|")
            lines.append(f"| `{escaped}` | {owners} | {record['status']} | {evidence} |")
        lines.append("")
    lines.extend(["## Per-extension coverage", "", "| Extension | Source files | Capability rows |", "|---|---:|---:|"])
    file_records = provenance["files"]
    for extension in sorted(EXPECTED_EXTENSIONS):
        count = sum(extension in owners for category in CATEGORIES for owners in rows[category].values())
        lines.append(f"| `{extension}` | {len(file_records[extension]) - 1} | {count} |")
    lines.append("")
    counts = ", ".join(f"{category}={len(rows[category])}" for category in CATEGORIES)
    lines.extend([f"Inventory counts: extensions=15, source_files={sum(len(v) - 1 for v in file_records.values())}, {counts}.", ""])
    return "\n".join(lines)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--check", action="store_true")
    parser.add_argument("--refresh-fixtures", metavar="PI_FLAKE_CHECKOUT", type=Path)
    parser.add_argument("--print-extracted", action="store_true", help=argparse.SUPPRESS)
    args = parser.parse_args()
    try:
        if args.refresh_fixtures:
            refresh_fixtures(args.refresh_fixtures.resolve())
        provenance, sources = load_and_validate_fixtures()
        rows = extract(sources)
        if args.print_extracted:
            serializable = {
                category: {item: sorted(owners) for item, owners in sorted(values.items())}
                for category, values in rows.items()
            }
            print(json.dumps(serializable, indent=2))
            return 0
        manifest = json.loads(MANIFEST.read_text())
        classified = validate_manifest(rows, manifest)
        generated = render(provenance, rows, classified)
        if args.check:
            current = OUTPUT.read_text() if OUTPUT.exists() else ""
            if current != generated:
                print(f"{OUTPUT.relative_to(ROOT)} is stale; run scripts/external-extension-inventory", file=sys.stderr)
                return 1
            print("external extension inventory is complete and current")
            return 0
        OUTPUT.write_text(generated)
        print(f"wrote {OUTPUT.relative_to(ROOT)}")
        return 0
    except (OSError, ValueError, json.JSONDecodeError, subprocess.CalledProcessError) as error:
        print(f"external extension inventory: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
