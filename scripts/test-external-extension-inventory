#!/usr/bin/env bash
set -euo pipefail

root=$(cd "$(dirname "$0")/.." && pwd)
work=$(mktemp -d)
trap 'rm -rf "$work"' EXIT

make_case() {
  local name=$1
  mkdir -p "$work/$name/scripts" "$work/$name/tests"
  cp "$root/scripts/external-extension-inventory" "$work/$name/scripts/"
  cp "$root/EXTERNAL_EXTENSION_INVENTORY.md" "$work/$name/"
  cp -R "$root/tests/external-extension-inventory" "$work/$name/tests/"
  chmod -R u+w "$work/$name"
}

# Baseline and generation are byte-idempotent without an ambient pi-flake checkout.
make_case baseline
(
  cd "$work/baseline"
  python3 scripts/external-extension-inventory --check
  cp EXTERNAL_EXTENSION_INVENTORY.md before.md
  python3 scripts/external-extension-inventory
  cmp before.md EXTERNAL_EXTENSION_INVENTORY.md
  python3 scripts/external-extension-inventory
  cmp before.md EXTERNAL_EXTENSION_INVENTORY.md
)

update_hash() {
  local case_dir=$1 extension=$2 relative=$3
  CASE_DIR=$case_dir EXTENSION=$extension RELATIVE=$relative python3 - <<'PY'
import hashlib
import json
import os
from pathlib import Path

root = Path(os.environ["CASE_DIR"])
extension = os.environ["EXTENSION"]
relative = os.environ["RELATIVE"]
source = root / "tests/external-extension-inventory/fixtures" / extension / relative
provenance_path = root / "tests/external-extension-inventory/provenance.json"
provenance = json.loads(provenance_path.read_text())
provenance["files"][extension][relative] = hashlib.sha256(source.read_bytes()).hexdigest()
entries = [
    f"{name}/{path}\0{digest}"
    for name, files in sorted(provenance["files"].items())
    for path, digest in sorted(files.items())
]
digest = hashlib.sha256("\n".join(entries).encode()).hexdigest()
provenance["fixture_digest"] = digest
provenance_path.write_text(json.dumps(provenance, indent=2) + "\n")
script_path = root / "scripts/external-extension-inventory"
script = script_path.read_text()
script = script.replace(
    'FIXTURE_DIGEST = "7bf4166a0b4d3e2a7db7dd57faa381e04996849c464dcef0a34c3e93445856d2"',
    f'FIXTURE_DIGEST = "{digest}"',
)
script_path.write_text(script)
PY
}

# A source capability added to the pinned fixture cannot bypass classification.
make_case capability
printf '\npi.unclassifiedCapability();\n' >> "$work/capability/tests/external-extension-inventory/fixtures/pi-codex-fast/src/index.ts"
update_hash "$work/capability" pi-codex-fast src/index.ts
if python3 "$work/capability/scripts/external-extension-inventory" --check >"$work/capability.out" 2>&1; then
  echo "expected unclassified capability rejection" >&2
  exit 1
fi
grep -F "ExtensionAPI.unclassifiedCapability" "$work/capability.out"

# A new concrete Pi class dependency is independently visible and unclassified.
make_case private
printf '\nimport { SecretComponent } from "@earendil-works/pi-coding-agent";\n' >> "$work/private/tests/external-extension-inventory/fixtures/pi-codex-fast/src/index.ts"
update_hash "$work/private" pi-codex-fast src/index.ts
PRIVATE_DIR="$work/private" python3 - <<'PY'
import json
import os
from pathlib import Path

path = Path(os.environ["PRIVATE_DIR"]) / "tests/external-extension-inventory/manifest.json"
manifest = json.loads(path.read_text())
manifest["categories"]["package_imports"][0]["items"].append(
    "@earendil-works/pi-coding-agent#SecretComponent"
)
path.write_text(json.dumps(manifest, indent=2) + "\n")
PY
if python3 "$work/private/scripts/external-extension-inventory" --check >"$work/private.out" 2>&1; then
  echo "expected private Pi dependency rejection" >&2
  exit 1
fi
grep -F "private_pi: missing=['SecretComponent']" "$work/private.out"

# Fixture provenance and stale manifest rows both fail closed.
make_case tampered
printf '\n' >> "$work/tampered/tests/external-extension-inventory/fixtures/pi-codex-fast/src/index.ts"
if python3 "$work/tampered/scripts/external-extension-inventory" --check >"$work/tampered.out" 2>&1; then
  echo "expected fixture hash rejection" >&2
  exit 1
fi
grep -F "fixture hash mismatch" "$work/tampered.out"

make_case stale
STALE_DIR="$work/stale" python3 - <<'PY'
import json
import os
from pathlib import Path

path = Path(os.environ["STALE_DIR"]) / "tests/external-extension-inventory/manifest.json"
manifest = json.loads(path.read_text())
manifest["categories"]["private_pi"][0]["items"].append("RemovedPrivateClass")
path.write_text(json.dumps(manifest, indent=2) + "\n")
PY
if python3 "$work/stale/scripts/external-extension-inventory" --check >"$work/stale.out" 2>&1; then
  echo "expected stale classification rejection" >&2
  exit 1
fi
grep -F "stale=['RemovedPrivateClass']" "$work/stale.out"

echo "external extension inventory offline/idempotency/fail-closed checks passed"
