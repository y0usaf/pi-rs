#!/usr/bin/env bash
# Regenerate the system-prompt-parity oracle from Pi's real
# buildSystemPrompt / loadProjectContextFiles / tool definitions in
# ref/pi. The oracle pins pi-rs's Lua system-prompt port
# (crates/pi-rs-app/src/builtins/utils/system-prompt.lua) to the exact
# prompts Pi's coding agent sends; see tests/system-prompt-parity/.
set -euo pipefail
cd "$(dirname "$0")/.."
cases=tests/system-prompt-parity/cases.json
oracle=tests/system-prompt-parity/oracle.json
if [[ ! -x ref/pi/node_modules/.bin/tsx ]]; then
  nix shell nixpkgs#nodejs_22 --command sh -c 'cd ref/pi && corepack npm ci --ignore-scripts'
fi
nix shell nixpkgs#nodejs_22 --command \
  ref/pi/node_modules/.bin/tsx --tsconfig ref/pi/tsconfig.json \
  tests/system-prompt-parity/gen-oracle.ts "$cases" > "$oracle"
echo "wrote $oracle"
