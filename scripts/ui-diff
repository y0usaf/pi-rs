#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."
scenarios=(basic-turn markdown-turn editor-turn autocomplete-turn shell-turn provider-turn bash-turn resume-turn session-turn tree-turn compaction-turn tool-turn highlight-turn highlight-tool-turn selector-turn login-turn model-turn thinking-turn settings-turn scoped-models-turn trust-turn startup-changelog-turn reload-turn)
if [[ "${1:-}" == "--update-pi" ]]; then
  if [[ ! -x ref/pi/node_modules/.bin/tsx ]]; then
    nix shell nixpkgs#nodejs_22 --command sh -c 'cd ref/pi && corepack npm ci --ignore-scripts'
  fi
  for name in "${scenarios[@]}"; do
    scenario=tests/ui-parity/$name.json
    oracle=tests/ui-parity/$name.pi.json
    raw=$(mktemp)
    trap 'rm -f "$raw"' EXIT
    # FORCE_COLOR keeps chalk styling active when stdout is piped; without it
    # the oracle drops bold/italic attributes that real terminals see.
    # Ignore an installed Pi package path: the vendored snapshot owns assets.
    env -u PI_PACKAGE_DIR FORCE_COLOR=3 nix shell nixpkgs#nodejs_22 --command \
      ref/pi/node_modules/.bin/tsx --tsconfig ref/pi/tsconfig.json \
      "tests/ui-parity/pi-$name.ts" "$scenario" > "$raw"
    cargo run --quiet -p pi-rs-app --bin ui-diff -- "$scenario" "$oracle" "$raw"
    rm -f "$raw"
  done
fi
for name in "${scenarios[@]}"; do
  cargo run --quiet -p pi-rs-app --bin ui-diff -- \
    "tests/ui-parity/$name.json" "tests/ui-parity/$name.pi.json"
done
