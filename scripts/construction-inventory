#!/usr/bin/env python3
"""Generate/check the fail-closed first-party construction inventory."""

from __future__ import annotations

import argparse
import json
import re
import sys
from collections import Counter, defaultdict
from pathlib import Path

DEFAULT_ROOT = Path(__file__).resolve().parent.parent
PROVENANCE_PATH = Path("tests/construction-inventory/provenance.json")
MANIFEST_PATH = Path("tests/construction-inventory/manifest.json")
OUTPUT_PATH = Path("CONSTRUCTION_INVENTORY.md")
REQUIRED_FIELDS = {
    "id",
    "kind",
    "title",
    "packages",
    "public_declaration",
    "disable_path",
    "replacement_evidence",
    "status",
    "rung",
    "coverage",
    "anchors",
    "declarations",
    "rust_entrypoints",
}
ALLOWED_STATUS = {"implemented", "open", "DESIGN exception"}
DECLARATION_RE = re.compile(r"pi\.register_(command|tool|role)\s*\(\s*(?:[\"']([^\"']+)[\"']|\{)")


def load_json(root: Path, relative: Path) -> dict:
    value = json.loads((root / relative).read_text())
    if not isinstance(value, dict):
        raise ValueError(f"{relative}: expected an object")
    return value


def const_block(source: str, name: str) -> str:
    match = re.search(rf"\bpub\s+const\s+{re.escape(name)}\b[^=]*=", source)
    if not match:
        raise ValueError(f"missing embedded-pack constant {name}")
    start = source.find("{", match.end())
    if start < 0:
        raise ValueError(f"missing body for embedded-pack constant {name}")
    depth = 0
    for index in range(start, len(source)):
        if source[index] == "{":
            depth += 1
        elif source[index] == "}":
            depth -= 1
            if depth == 0:
                return source[start + 1 : index]
    raise ValueError(f"unterminated embedded-pack constant {name}")


def extract_embedded(root: Path, provenance: dict) -> tuple[dict[str, set[str]], dict[str, str]]:
    memberships: dict[str, set[str]] = defaultdict(set)
    package_names: dict[str, str] = {}
    for package in provenance.get("embedded_packages", []):
        package_id = package["id"]
        descriptor = root / package["descriptor"]
        source = descriptor.read_text()
        block = const_block(source, package["constant"])
        name_match = re.search(r'\bname\s*:\s*"([^"]+)"', block)
        if not name_match:
            raise ValueError(f"{package_id}: embedded pack has no literal name")
        actual_name = name_match.group(1)
        if actual_name != package["source_name"]:
            raise ValueError(
                f"{package_id}: source name changed: expected {package['source_name']!r}, got {actual_name!r}"
            )
        if package_id in package_names:
            raise ValueError(f"duplicate embedded package id {package_id}")
        package_names[package_id] = actual_name
        includes = re.findall(r'include_(?:str|bytes)!\("([^"]+)"\)', block)
        if not includes:
            raise ValueError(f"{package_id}: embedded pack has no source units")
        for include in includes:
            resolved = (descriptor.parent / include).resolve()
            try:
                relative = resolved.relative_to(root.resolve()).as_posix()
            except ValueError as error:
                raise ValueError(f"{package_id}: source escapes repository: {include}") from error
            if not resolved.is_file():
                raise ValueError(f"{package_id}: missing embedded source {relative}")
            memberships[relative].add(package_id)
    if not package_names:
        raise ValueError("provenance has no embedded packages")
    return dict(memberships), package_names


def extract_declarations(root: Path, embedded: dict[str, set[str]]) -> set[str]:
    declarations: set[str] = set()
    for relative in sorted(embedded):
        if not relative.endswith(".lua"):
            continue
        source = (root / relative).read_text()
        for match in DECLARATION_RE.finditer(source):
            kind, literal = match.groups()
            if kind == "command":
                if literal is None:
                    raise ValueError(f"{relative}: register_command must use a literal name for inventory")
                name = literal
            else:
                block = source[match.end() :]
                field = "role" if kind == "role" else "name"
                name_match = re.search(rf'\b{field}\s*=\s*["\']([^"\']+)["\']', block)
                if not name_match:
                    raise ValueError(
                        f"{relative}: register_{kind} must have a literal {field} for inventory"
                    )
                name = name_match.group(1)
            key = f"{kind}:{name}"
            if key in declarations:
                raise ValueError(f"duplicate embedded declaration {key}")
            declarations.add(key)
    return declarations


def extract_rust_entrypoints(root: Path, provenance: dict) -> Counter[str]:
    pattern = re.compile(provenance["rust_entrypoint_pattern"])
    found: Counter[str] = Counter()
    for relative in provenance["rust_source_roots"]:
        base = root / relative
        for path in sorted(base.rglob("*.rs")):
            for match in pattern.finditer(path.read_text()):
                found[match.group(1)] += 1
    return found


def validate_anchors(root: Path, rows: list[dict]) -> None:
    for row in rows:
        for anchor in row["anchors"]:
            if set(anchor) != {"path", "text", "count"}:
                raise ValueError(f"{row['id']}: anchor fields must be path/text/count")
            source = (root / anchor["path"]).read_text()
            actual = source.count(anchor["text"])
            if actual != anchor["count"]:
                raise ValueError(
                    f"{row['id']}: stale anchor {anchor['path']}:{anchor['text']!r}; "
                    f"expected {anchor['count']}, got {actual}"
                )


def validate_scans(root: Path, provenance: dict, row_ids: set[str]) -> None:
    seen: set[str] = set()
    for scan in provenance.get("rust_seams", []):
        scan_id = scan["id"]
        if scan_id in seen:
            raise ValueError(f"duplicate Rust seam provenance {scan_id}")
        seen.add(scan_id)
        if scan["row"] not in row_ids:
            raise ValueError(f"Rust seam {scan_id}: missing row {scan['row']}")
        actual = (root / scan["path"]).read_text().count(scan["text"])
        if actual != scan["count"]:
            raise ValueError(
                f"Rust seam {scan_id} is stale: expected {scan['count']} occurrences of "
                f"{scan['text']!r}, got {actual}"
            )

    expected_calls: Counter[tuple[str, str]] = Counter()
    for call in provenance.get("rust_call_inventory", []):
        if call["row"] not in row_ids:
            raise ValueError(f"Rust call {call['path']}:{call['operation']}: missing row {call['row']}")
        key = (call["path"], call["operation"])
        if key in expected_calls:
            raise ValueError(f"duplicate Rust call inventory {key}")
        expected_calls[key] = call["count"]
    operations = tuple(provenance.get("rust_call_operations", []))
    actual_calls: Counter[tuple[str, str]] = Counter()
    for source_root in provenance.get("rust_source_roots", []):
        for path in sorted((root / source_root).rglob("*.rs")):
            source = path.read_text()
            relative = path.relative_to(root).as_posix()
            for operation in operations:
                count = source.count(f".{operation}(")
                if count:
                    actual_calls[(relative, operation)] = count
    if actual_calls != expected_calls:
        def printable(values: Counter[tuple[str, str]]) -> dict[str, int]:
            return {f"{path}:{operation}": count for (path, operation), count in sorted(values.items())}

        raise ValueError(
            "Rust launch/composition calls differ: "
            f"extracted={printable(actual_calls)}, inventoried={printable(expected_calls)}"
        )


def validate(root: Path, provenance: dict, manifest: dict) -> tuple[dict[str, set[str]], set[str], Counter[str]]:
    if provenance.get("schema") != 1 or manifest.get("schema") != 1:
        raise ValueError("provenance/manifest schema must be 1")
    if provenance.get("oracle") != "Pi v0.79.0 c5582102":
        raise ValueError("provenance oracle must be Pi v0.79.0 c5582102")
    rows = manifest.get("rows")
    if not isinstance(rows, list) or not rows:
        raise ValueError("manifest rows must be a non-empty array")

    ids: set[str] = set()
    for row in rows:
        if not isinstance(row, dict):
            raise ValueError("manifest row must be an object")
        fields = set(row)
        if fields != REQUIRED_FIELDS:
            raise ValueError(
                f"{row.get('id', '<unknown>')}: row fields differ; "
                f"missing={sorted(REQUIRED_FIELDS-fields)}, extra={sorted(fields-REQUIRED_FIELDS)}"
            )
        row_id = row["id"]
        if not isinstance(row_id, str) or not re.fullmatch(r"[a-z0-9][a-z0-9._-]*", row_id):
            raise ValueError(f"invalid row id {row_id!r}")
        if row_id in ids:
            raise ValueError(f"duplicate row id {row_id}")
        ids.add(row_id)
        for field in ("kind", "title", "public_declaration", "disable_path", "replacement_evidence", "rung"):
            if not isinstance(row[field], str) or not row[field].strip():
                raise ValueError(f"{row_id}: {field} is required")
        if row["status"] not in ALLOWED_STATUS:
            raise ValueError(f"{row_id}: invalid status {row['status']!r}")
        if not isinstance(row["packages"], list) or not row["packages"]:
            raise ValueError(f"{row_id}: packages must be non-empty")
        for field in ("coverage", "anchors", "declarations", "rust_entrypoints"):
            if not isinstance(row[field], list):
                raise ValueError(f"{row_id}: {field} must be an array")

    required_open = set(provenance.get("required_open_rows", []))
    missing_open = required_open - ids
    if missing_open:
        raise ValueError(f"missing named open rows: {sorted(missing_open)}")
    for row in rows:
        if row["id"] in required_open and row["status"] != "open":
            raise ValueError(f"{row['id']}: named row must remain open until its owning rung closes it")

    embedded, package_names = extract_embedded(root, provenance)
    known_packages = set(package_names) | set(provenance.get("non_embedded_packages", []))
    coverage: dict[str, list[str]] = defaultdict(list)
    for row in rows:
        unknown = set(row["packages"]) - known_packages
        if unknown:
            raise ValueError(f"{row['id']}: unknown packages {sorted(unknown)}")
        for source in row["coverage"]:
            coverage[source].append(row["id"])
    missing_sources = sorted(set(embedded) - set(coverage))
    stale_sources = sorted(set(coverage) - set(embedded))
    duplicate_sources = {path: owners for path, owners in coverage.items() if len(owners) != 1}
    if missing_sources or stale_sources or duplicate_sources:
        raise ValueError(
            f"embedded source coverage differs: missing={missing_sources}, stale={stale_sources}, "
            f"duplicates={duplicate_sources}"
        )
    by_id = {row["id"]: row for row in rows}
    for source, packages in embedded.items():
        row = by_id[coverage[source][0]]
        if set(row["packages"]) != packages:
            raise ValueError(
                f"{row['id']}: package membership for {source} differs: "
                f"expected {sorted(packages)}, got {sorted(row['packages'])}"
            )

    extracted_declarations = extract_declarations(root, embedded)
    declared: dict[str, list[str]] = defaultdict(list)
    for row in rows:
        for declaration in row["declarations"]:
            declared[declaration].append(row["id"])
    missing_declarations = sorted(extracted_declarations - set(declared))
    stale_declarations = sorted(set(declared) - extracted_declarations)
    duplicate_declarations = {key: owners for key, owners in declared.items() if len(owners) != 1}
    if missing_declarations or stale_declarations or duplicate_declarations:
        raise ValueError(
            f"embedded declarations differ: missing={missing_declarations}, stale={stale_declarations}, "
            f"duplicates={duplicate_declarations}"
        )

    extracted_entrypoints = extract_rust_entrypoints(root, provenance)
    inventoried_entrypoints: Counter[str] = Counter()
    for row in rows:
        for entry in row["rust_entrypoints"]:
            if set(entry) != {"name", "count"} or not isinstance(entry["count"], int):
                raise ValueError(f"{row['id']}: Rust entrypoint must have name/count")
            inventoried_entrypoints[entry["name"]] += entry["count"]
    if extracted_entrypoints != inventoried_entrypoints:
        raise ValueError(
            "hardcoded Rust product entrypoints differ: "
            f"extracted={dict(sorted(extracted_entrypoints.items()))}, "
            f"inventoried={dict(sorted(inventoried_entrypoints.items()))}"
        )

    validate_anchors(root, rows)
    validate_scans(root, provenance, ids)
    return embedded, extracted_declarations, extracted_entrypoints


def render(provenance: dict, manifest: dict, embedded: dict[str, set[str]]) -> str:
    lines = [
        "# First-party construction inventory",
        "",
        "Generated by `scripts/construction-inventory` from checked provenance and the",
        "embedded pack descriptors. Edit `tests/construction-inventory/manifest.json`,",
        "then regenerate. `--check` fails closed for missing/stale/duplicate sources,",
        "declarations, Rust seams, hardcoded product entrypoints, or named open rows.",
        "",
        f"Oracle: `{provenance['oracle']}`. Audit base: `{provenance['audit_base']}`.",
        "",
        "| ID | Kind | Unit | Package(s) | Public declaration | Disable path | Replacement evidence | Status | Rung |",
        "|---|---|---|---|---|---|---|---|---|",
    ]
    for row in sorted(manifest["rows"], key=lambda item: item["id"]):
        values = [
            f"`{row['id']}`",
            row["kind"],
            row["title"],
            ", ".join(f"`{package}`" for package in row["packages"]),
            row["public_declaration"],
            row["disable_path"],
            row["replacement_evidence"],
            row["status"],
            row["rung"],
        ]
        lines.append("| " + " | ".join(value.replace("|", "\\|").replace("\n", " ") for value in values) + " |")
    status_counts = Counter(row["status"] for row in manifest["rows"])
    lines += [
        "",
        f"Rows: {len(manifest['rows'])}; embedded source units: {len(embedded)}; "
        + "; ".join(f"{status}={status_counts[status]}" for status in sorted(status_counts))
        + ".",
        "",
    ]
    return "\n".join(lines)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--check", action="store_true")
    parser.add_argument("--root", type=Path, default=DEFAULT_ROOT, help=argparse.SUPPRESS)
    parser.add_argument("--print-extracted", action="store_true", help=argparse.SUPPRESS)
    args = parser.parse_args()
    root = args.root.resolve()
    try:
        provenance = load_json(root, PROVENANCE_PATH)
        manifest = load_json(root, MANIFEST_PATH)
        embedded, declarations, entrypoints = validate(root, provenance, manifest)
        if args.print_extracted:
            print(json.dumps({
                "embedded": {path: sorted(packages) for path, packages in sorted(embedded.items())},
                "declarations": sorted(declarations),
                "rust_entrypoints": dict(sorted(entrypoints.items())),
            }, indent=2))
            return 0
        generated = render(provenance, manifest, embedded)
        output = root / OUTPUT_PATH
        if args.check:
            current = output.read_text() if output.exists() else ""
            if current != generated:
                print(f"{OUTPUT_PATH} is stale; run scripts/construction-inventory", file=sys.stderr)
                return 1
            print("construction inventory is complete and current")
            return 0
        output.write_text(generated)
        print(f"wrote {OUTPUT_PATH}")
        return 0
    except (OSError, ValueError, KeyError, TypeError, json.JSONDecodeError) as error:
        print(f"construction inventory: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
