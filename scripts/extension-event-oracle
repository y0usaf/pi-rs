#!/usr/bin/env bash
# Regenerate PLAN 9.3's event/fold oracle from Pi v0.79.0.
set -euo pipefail
cd "$(dirname "$0")/.."
oracle=tests/extension-event-parity/oracle.json
if [[ ! -x ref/pi/node_modules/.bin/tsx ]]; then
  nix shell nixpkgs#nodejs_22 --command sh -c 'cd ref/pi && corepack npm ci --ignore-scripts'
fi
nix shell nixpkgs#bun --command bun \
  tests/extension-event-parity/gen-oracle.ts > "$oracle"
echo "wrote $oracle"
