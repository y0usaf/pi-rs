#!/usr/bin/env bash
# Regenerate the jsdiff-parity oracle from the vendored jsdiff 8.0.4 in
# ref/pi. The oracle pins pi.diff.* (crates/pi-rs-host/src/jsdiff.rs) to the
# exact library Pi's coding agent uses; see tests/jsdiff-parity/.
set -euo pipefail
cd "$(dirname "$0")/.."
cases=tests/jsdiff-parity/cases.json
oracle=tests/jsdiff-parity/oracle.json
if [[ ! -x ref/pi/node_modules/.bin/tsx ]]; then
  nix shell nixpkgs#nodejs_22 --command sh -c 'cd ref/pi && corepack npm ci --ignore-scripts'
fi
nix shell nixpkgs#nodejs_22 --command \
  ref/pi/node_modules/.bin/tsx --tsconfig ref/pi/tsconfig.json \
  tests/jsdiff-parity/gen-oracle.ts "$cases" > "$oracle"
echo "wrote $oracle"
