#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."
if [[ ! -x ref/pi/node_modules/.bin/tsx ]]; then
  nix shell nixpkgs#nodejs_22 --command sh -c 'cd ref/pi && corepack npm ci --ignore-scripts'
fi
env -u AWS_BEARER_TOKEN_BEDROCK -u AWS_PROFILE -u AWS_REGION -u AWS_DEFAULT_REGION nix shell nixpkgs#nodejs_22 --command ref/pi/node_modules/.bin/tsx --tsconfig ref/pi/tsconfig.json tests/bedrock-converse-stream-parity/gen-oracle.ts tests/bedrock-converse-stream-parity/cases.json > tests/bedrock-converse-stream-parity/oracle.json
echo "wrote tests/bedrock-converse-stream-parity/oracle.json"
