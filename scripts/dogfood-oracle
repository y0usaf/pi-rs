#!/usr/bin/env python3
"""Check/generate the pinned pi-flake dogfood fixture contract.

Normal checks consume only checked-in provenance. Pass --source to additionally
verify it against a pi-flake checkout at the pinned revision.
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
CONTRACT = ROOT / "tests/dogfood-suite/contract.json"
OUTPUT = ROOT / "DOGFOOD_SUITE.md"
REVISION = "94694da7321ce74aa7b82c13db7e60e28c0caba6"
ROOT_TREE = "d618b6d10b574a8624991b055838e7a16e8c8a35"
EXTENSIONS_TREE = "c4a04dfe88314b5e48ebb200ccfd546645c3af9e"

# Deliberately duplicated outside contract.json: changing a checked fixture
# cannot silently rewrite the pinned source identity or suite membership.
PACKAGES = [
    ("codex-fast", "pi-codex-fast", "pi-codex-fast", "1.0.0", "src/index.ts", "d986679665640e82610eb3a207177f1a213556e2", True),
    ("gecko-websearch", "pi-gecko-websearch", "pi-gecko-websearch", "1.0.0", "src/index.ts", "d14e1be3c3518a73d8e847850e4aa66b90081f22", True),
    ("rtk", "pi-rtk", "@sherif-fanous/pi-rtk", "0.3.0", "index.ts", "aed5f7967be1d941ebef3f7fb40dbba81c1db688", True),
    ("compact", "pi-compact", "pi-compact", "0.1.0", "src/index.ts", "d0985c0c44c23def835c813b0977b0da90befb13", True),
    ("context-janitor", "pi-context-janitor", "pi-context-janitor", "0.1.0", "src/index.ts", "8b0a34c91ec7102fda8e666d9af0512536bd4481", True),
    ("morph", "pi-morph", "pi-morph", "0.1.0", "src/index.ts", "053b9195a0d598a0d5b22461a03bf07c7b5e4f5f", False),
    ("tool-management", "pi-tool-management", "pi-tool-management", "1.0.0", "src/index.ts", "a073980dd35a9a4f73985445b8bfe42c08606283", True),
    ("webfetch", "pi-webfetch", "pi-webfetch", "1.0.0", "src/index.ts", "6a13fa1bb8b47cb48e9a5bb81d42ea1be1afaf43", True),
    ("hashline", "pi-hashline", "pi-hashline", "0.2.0", "src/index.ts", "7496e74f6bedea661678e7709178ced1123279c9", True),
    ("minimal-editor", "pi-minimal-editor", "pi-minimal-editor", "0.1.0", "src/index.ts", "2b61951f3b0c4d3222dedc84e30efa1b199cfd32", True),
    ("working-indicator", "pi-working-indicator", "pi-working-indicator", "0.1.0", "extensions/index.ts", "8ec6bb77bcdcc4b1383952b9c0e95810e18bee06", True),
    ("pomodoro", "pi-pomodoro", "pi-pomodoro", "1.0.0", "src/index.ts", "83f4405a76741b883440aaa3e58eb3befd6082a2", True),
    ("rlm", "pi-rlm", "pi-rlm", "0.1.0", "src/index.ts", "80c5f219c04d502b27092e9b02aef8725d9967ec", True),
    ("review", "earendil_pi-review", "@earendil-works/pi-review", "0.1.0", "review.ts", "0d2767278f978ea450ee471c2f7b01030256323c", True),
    ("vcc", "sting8k_pi-vcc", "@sting8k/pi-vcc", "0.3.12", "index.ts", "0387247559584cc50dde0781f4695234b6afd442", True),
]

FIXTURE_KINDS = {
    "provider",
    "browser_socket",
    "subprocess",
    "timer",
    "filesystem",
    "compaction",
    "session",
    "terminal",
}
LOAD_MODES = ["direct", "configured", "bundled"]


def git(source: Path, *args: str) -> str:
    proc = subprocess.run(
        ["git", "-C", str(source), *args],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if proc.returncode:
        raise ValueError(proc.stderr.strip() or f"git {' '.join(args)} failed")
    return proc.stdout.strip()


def validate_source(source: Path) -> None:
    if git(source, "rev-parse", "HEAD") != REVISION:
        raise ValueError(f"source HEAD must be {REVISION}")
    if git(source, "rev-parse", "HEAD^{tree}") != ROOT_TREE:
        raise ValueError("pinned pi-flake root tree differs")
    if git(source, "rev-parse", "HEAD:extensions") != EXTENSIONS_TREE:
        raise ValueError("pinned pi-flake extensions tree differs")

    flake = (source / "flake.nix").read_text()
    for package in PACKAGES:
        ident, directory, package_name, version, entrypoint, tree, default = package
        actual_tree = git(source, "rev-parse", f"HEAD:extensions/{directory}")
        if actual_tree != tree:
            raise ValueError(f"{ident}: source tree differs ({actual_tree})")
        metadata = json.loads((source / "extensions" / directory / "package.json").read_text())
        if metadata.get("name") != package_name or metadata.get("version") != version:
            raise ValueError(f"{ident}: package name/version differs")
        declared = metadata.get("pi", {}).get("extensions", []) if metadata.get("pi") else []
        declared = [value.removeprefix("./") for value in declared]
        if declared and declared != [entrypoint]:
            raise ValueError(f"{ident}: entrypoint differs: {declared}")
        if not (source / "extensions" / directory / entrypoint).is_file():
            raise ValueError(f"{ident}: missing entrypoint {entrypoint}")
        package_ref = f'self.packages.${{system}}."pi-{ident}";'
        declarations = (f'{ident} = {package_ref}', f'"{ident}" = {package_ref}')
        if not any(declaration in flake for declaration in declarations):
            raise ValueError(f"{ident}: missing extensionPackagesFor declaration")
    if '["morph"]' not in flake:
        raise ValueError("source default bundle no longer excludes only morph")


def validate(contract: dict) -> None:
    oracle = contract.get("oracle", {})
    expected_oracle = {
        "repository": "pi-flake",
        "revision": REVISION,
        "pi_runtime": "0.80.6",
        "root_tree": ROOT_TREE,
        "extensions_tree": EXTENSIONS_TREE,
    }
    if oracle != expected_oracle:
        raise ValueError(f"oracle differs: expected {expected_oracle}, got {oracle}")

    rows = contract.get("packages")
    if not isinstance(rows, list):
        raise ValueError("packages must be a list")
    expected_ids = [package[0] for package in PACKAGES]
    ids = [row.get("id") for row in rows]
    if ids != expected_ids:
        raise ValueError(f"package order/membership differs: expected {expected_ids}, got {ids}")
    if len(ids) != len(set(ids)):
        raise ValueError("duplicate package id")

    seen_cases: set[str] = set()
    seen_kinds: set[str] = set()
    for row, package in zip(rows, PACKAGES, strict=True):
        ident, directory, package_name, version, entrypoint, tree, default = package
        expected_source = {
            "directory": directory,
            "package_name": package_name,
            "version": version,
            "entrypoint": entrypoint,
            "tree": tree,
        }
        if row.get("source") != expected_source:
            raise ValueError(f"{ident}: source provenance differs")
        if row.get("default_bundle") is not default:
            raise ValueError(f"{ident}: default_bundle differs")
        if row.get("load_modes") != LOAD_MODES:
            raise ValueError(f"{ident}: load_modes must be {LOAD_MODES}")
        cases = row.get("cases")
        if not isinstance(cases, list) or not cases:
            raise ValueError(f"{ident}: at least one deterministic case is required")
        cleanup = row.get("cleanup")
        if not isinstance(cleanup, list) or not cleanup or any(not str(item).strip() for item in cleanup):
            raise ValueError(f"{ident}: explicit lifecycle cleanup assertions are required")
        for case in cases:
            case_id = case.get("id")
            if not isinstance(case_id, str) or not case_id.startswith(f"{ident}."):
                raise ValueError(f"{ident}: invalid case id {case_id!r}")
            if case_id in seen_cases:
                raise ValueError(f"duplicate case id {case_id}")
            seen_cases.add(case_id)
            kinds = case.get("kinds")
            if not isinstance(kinds, list) or not kinds or not set(kinds) <= FIXTURE_KINDS:
                raise ValueError(f"{case_id}: invalid fixture kinds {kinds!r}")
            seen_kinds.update(kinds)
            if not isinstance(case.get("script"), dict) or not case["script"]:
                raise ValueError(f"{case_id}: scripted inputs are required")
            if not isinstance(case.get("expect"), dict) or not case["expect"]:
                raise ValueError(f"{case_id}: expected observations are required")

    if seen_kinds != FIXTURE_KINDS:
        raise ValueError(f"fixture kind coverage differs: missing={sorted(FIXTURE_KINDS - seen_kinds)}")
    bundle = contract.get("bundles", {})
    all_ids = expected_ids
    default_ids = [package[0] for package in PACKAGES if package[6]]
    if bundle != {"all": all_ids, "default": default_ids}:
        raise ValueError("bundle composition differs from package declarations")


def render(contract: dict) -> str:
    lines = [
        "# Maintained dogfood suite",
        "",
        f"Fixture contract for `pi-flake` `{REVISION}` (Pi 0.80.6).",
        "The source runtime is an extension-behavior oracle only; pi-rs product parity remains pinned to Pi v0.79.0.",
        "",
        "Normal checks consume `tests/dogfood-suite/contract.json` and do not require a sibling checkout.",
        "`scripts/dogfood-oracle --source /path/to/pi-flake --check` additionally verifies the pinned source trees and package declarations.",
        "",
        "| Package | Upstream source | Version | Default bundle | Fixture cases | Cleanup assertions |",
        "|---|---|---:|:---:|---:|---|",
    ]
    for row in contract["packages"]:
        cleanup = "; ".join(row["cleanup"]).replace("|", "\\|")
        lines.append(
            f"| `{row['id']}` | `{row['source']['directory']}/{row['source']['entrypoint']}` | "
            f"{row['source']['version']} | {'yes' if row['default_bundle'] else 'no'} | "
            f"{len(row['cases'])} | {cleanup} |"
        )
    lines += [
        "",
        "## Deterministic fixture coverage",
        "",
        "| Case | Kinds | Scripted boundary | Expected observation |",
        "|---|---|---|---|",
    ]
    for row in contract["packages"]:
        for case in row["cases"]:
            script = ", ".join(case["script"].keys()).replace("|", "\\|")
            expect = ", ".join(case["expect"].keys()).replace("|", "\\|")
            lines.append(f"| `{case['id']}` | {', '.join(case['kinds'])} | {script} | {expect} |")
    lines += [
        "",
        "Load modes pinned for every package: direct file, configured package, and Nix bundle.",
        "The default source bundle contains 14 packages and excludes opt-in `morph`; the all-package acceptance bundle contains all 15.",
        "",
        "This fixture-only preflight intentionally contains no inert translation packages: executable Lua translations depend on the public lifecycle/module/mechanism work owned by PLAN 9.2–9.9.",
        "",
    ]
    return "\n".join(lines)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--check", action="store_true")
    parser.add_argument("--source", type=Path)
    args = parser.parse_args()
    try:
        contract = json.loads(CONTRACT.read_text())
        validate(contract)
        if args.source:
            validate_source(args.source.resolve())
        generated = render(contract)
        if args.check:
            current = OUTPUT.read_text() if OUTPUT.exists() else ""
            if current != generated:
                print(f"{OUTPUT.relative_to(ROOT)} is stale; run scripts/dogfood-oracle", file=sys.stderr)
                return 1
            print("dogfood fixture contract is complete and current")
            return 0
        OUTPUT.write_text(generated)
        print(f"wrote {OUTPUT.relative_to(ROOT)}")
        return 0
    except (OSError, ValueError, json.JSONDecodeError) as error:
        print(f"dogfood oracle: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
